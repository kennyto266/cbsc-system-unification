# CBSC System Environment Configuration Template
# Copy this file to .env and customize for your environment

# =============================================================================
# 数据库配置 (Database Configuration)
# =============================================================================
POSTGRES_DB=cbsc_production
POSTGRES_USER=cbsc_admin
POSTGRES_PASSWORD=your_secure_postgres_password_here
DATABASE_URL=postgresql://cbsc_admin:your_secure_postgres_password_here@localhost:5432/cbsc_production

# =============================================================================
# Redis配置 (Redis Configuration)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_secure_redis_password_here

# =============================================================================
# API网关配置 (API Gateway Configuration)
# =============================================================================
GATEWAY_SECRET_KEY=your_extremely_secure_gateway_secret_key_change_this_in_production
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_ALGORITHM=HS256
TOKEN_EXPIRE_MINUTES=1440

# =============================================================================
# 服务URL配置 (Service URLs Configuration)
# =============================================================================
# 内部服务URL（Docker网络）
QUANT_SYSTEM_URL=http://quant-system:8001
USER_MANAGEMENT_URL=http://user-management:3004
STRATEGY_DASHBOARD_URL=http://strategy-dashboard:3003
CONFIG_SERVICE_URL=http://config-service:3005

# 外部服务URL（本地开发）
FRONTEND_URL=http://localhost:3000
UNIFIED_DASHBOARD_URL=http://localhost:3001

# =============================================================================
# 应用配置 (Application Configuration)
# =============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO
DEBUG=false
NODE_ENV=production

# =============================================================================
# CORS配置 (CORS Configuration)
# =============================================================================
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# 开发环境: CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# 安全配置 (Security Configuration)
# =============================================================================
RATE_LIMIT_ENABLED=true
MAX_REQUESTS_PER_IP=1000
RATE_LIMIT_WINDOW=60
AUTH_ENABLED=true

# =============================================================================
# 监控配置 (Monitoring Configuration)
# =============================================================================
GRAFANA_PASSWORD=your_grafana_admin_password
PROMETHEUS_RETENTION=30d

# =============================================================================
# 邮件配置 (Email Configuration)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_TLS=true
SMTP_SSL=false
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=CBSC System

# =============================================================================
# 文件上传配置 (File Upload Configuration)
# =============================================================================
MAX_UPLOAD_SIZE=52428800
UPLOAD_PATH=/app/uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,csv,xlsx,xls

# =============================================================================
# 缓存配置 (Cache Configuration)
# =============================================================================
CACHE_TTL=3600
CACHE_PREFIX=cbsc
CACHE_MAX_SIZE=1000

# =============================================================================
# 数据库连接池配置 (Database Pool Configuration)
# =============================================================================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# =============================================================================
# API限流配置 (API Rate Limiting)
# =============================================================================
API_RATE_LIMIT_DEFAULT=100/minute
API_RATE_LIMIT_BURST=200
API_RATE_LIMIT_AUTH=1000/minute

# =============================================================================
# SSL/TLS配置 (SSL/TLS Configuration)
# =============================================================================
SSL_ENABLED=true
SSL_CERT_PATH=/app/ssl/cert.pem
SSL_KEY_PATH=/app/ssl/key.pem
SSL_CHAIN_PATH=/app/ssl/chain.pem

# =============================================================================
# 会话配置 (Session Configuration)
# =============================================================================
SESSION_SECRET=your_session_secret_key
SESSION_TIMEOUT=3600
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true

# =============================================================================
# 日志配置 (Logging Configuration)
# =============================================================================
LOG_FORMAT=json
LOG_FILE_PATH=/app/logs/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10

# =============================================================================
# 第三方服务配置 (Third-party Service Configuration)
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# 微信登录
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# =============================================================================
# 性能配置 (Performance Configuration)
# =============================================================================
WORKERS=4
WORKER_CONNECTIONS=1000
MAX_REQUESTS=10000
KEEP_ALIVE=2

# =============================================================================
# 开发环境特定配置 (Development Environment Only)
# =============================================================================
# 取消注释以下行用于开发环境
# ENVIRONMENT=development
# LOG_LEVEL=DEBUG
# DEBUG=true
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
# RATE_LIMIT_ENABLED=false

# =============================================================================
# 测试环境配置 (Testing Environment Only)
# =============================================================================
# 取消注释以下行用于测试环境
# ENVIRONMENT=testing
# LOG_LEVEL=WARNING
# DATABASE_URL=postgresql://cbsc_test:test_password@localhost:5432/cbsc_test
# REDIS_URL=redis://localhost:6380/1

# =============================================================================
# 生产环境安全提醒 (Production Environment Security Reminders)
# =============================================================================
# 重要提醒：
# 1. 更改所有默认密码和密钥
# 2. 使用强密码和长随机密钥
# 3. 定期轮换密钥和密码
# 4. 不要在版本控制中提交真实的密钥
# 5. 使用环境变量或密钥管理服务
# 6. 启用SSL/TLS加密
# 7. 配置防火墙和安全组
# 8. 定期更新依赖包
# 9. 启用日志监控和告警
# 10. 实施备份和恢复策略

# =============================================================================
# 端口配置 (Port Configuration)
# =============================================================================
FRONTEND_PORT=3000
UNIFIED_DASHBOARD_PORT=3001
API_GATEWAY_PORT=8000
USER_MANAGEMENT_PORT=3004
STRATEGY_DASHBOARD_PORT=3003
CONFIG_SERVICE_PORT=3005
POSTGRES_PORT=5432
REDIS_PORT=6379
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
GRAFANA_PORT=3002
PROMETHEUS_PORT=9090

# =============================================================================
# 域名配置 (Domain Configuration)
# =============================================================================
DOMAIN=yourdomain.com
SUBDOMAIN_API=api.yourdomain.com
SUBDOMAIN_APP=app.yourdomain.com
SUBDOMAIN_ADMIN=admin.yourdomain.com
SUBDOMAIN_MONITORING=monitoring.yourdomain.com

# =============================================================================
# 备份配置 (Backup Configuration)
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/app/backups
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1

# =============================================================================
# 通知配置 (Notification Configuration)
# =============================================================================
WEBHOOK_URL=https://hooks.slack.com/your/slack/webhook
NOTIFICATION_EMAIL=admin@yourdomain.com
ERROR_NOTIFICATION_ENABLED=true
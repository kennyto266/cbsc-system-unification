# =============================================================================
# CBSC 量化交易策略管理系统 - 环境配置模板
# =============================================================================
# 复制此文件为 .env.development, .env.test, 或 .env.production
# 并根据您的环境修改配置值
# =============================================================================

# =============================================================================
# 系统基础配置 (System Configuration)
# =============================================================================
# 系统环境: development | test | production
ENVIRONMENT=development

# 应用名称
APP_NAME=CBSC Quant Trading System

# 应用版本
APP_VERSION=1.0.0

# 调试模式 (仅开发环境启用)
DEBUG=false

# 日志级别: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# 数据库配置 (Database Configuration)
# =============================================================================
# PostgreSQL 主数据库
DATABASE_URL=postgresql://cbsc_user:your_secure_password@localhost:5432/cbsc_production
POSTGRES_DB=cbsc_production
POSTGRES_USER=cbsc_user
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# 数据库连接池配置
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# =============================================================================
# Redis 配置 (Redis Configuration)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your_secure_redis_password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Redis 连接池配置
REDIS_POOL_SIZE=50
REDIS_MAX_CONNECTIONS=100

# =============================================================================
# InfluxDB 配置 (InfluxDB Configuration - 时序数据库)
# =============================================================================
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influxdb_token
INFLUXDB_ORG=cbsc
INFLUXDB_BUCKET=market_data
INFLUXDB_USERNAME=cbsc_admin
INFLUXDB_PASSWORD=your_influxdb_password

# =============================================================================
# API 配置 (API Configuration)
# =============================================================================
# 主 API 服务
API_HOST=0.0.0.0
API_PORT=3004
API_PREFIX=/api/v1
API_VERSION=v1

# API 工作进程数 (生产环境建议设置为 CPU 核心数)
API_WORKERS=4

# API 速率限制
API_RATE_LIMIT_DEFAULT=100/minute
API_RATE_LIMIT_BURST=200
API_RATE_LIMIT_AUTH=1000/minute

# =============================================================================
# 安全配置 (Security Configuration)
# =============================================================================
# JWT 密钥 (生产环境必须使用强随机密钥，至少 32 字符)
JWT_SECRET=your_jwt_secret_key_change_this_in_production_minimum_32_characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# 应用密钥
SECRET_KEY=your_app_secret_key_change_this_in_production_minimum_32_characters

# 刷新令牌密钥
REFRESH_SECRET_KEY=your_refresh_token_secret_key_minimum_32_characters

# 会话配置
SESSION_SECRET=your_session_secret_key_minimum_32_characters
SESSION_TIMEOUT=3600
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true

# 加密配置
ENCRYPTION_KEY=your_32_byte_encryption_key_here
AES256_KEY=your_aes256_encryption_key_here

# =============================================================================
# CORS 配置 (CORS Configuration)
# =============================================================================
# 允许的跨域来源 (逗号分隔)
# 开发环境示例: http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
# 生产环境示例: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# CORS 允许的方法
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH

# CORS 允许的请求头
CORS_HEADERS=Content-Type,Authorization,X-Requested-With

# =============================================================================
# 服务端口配置 (Service Port Configuration)
# =============================================================================
FRONTEND_PORT=3000
UNIFIED_DASHBOARD_PORT=3001
API_GATEWAY_PORT=8000
USER_MANAGEMENT_PORT=3004
STRATEGY_DASHBOARD_PORT=3003
CONFIG_SERVICE_PORT=3005
WEBSOCKET_PORT=3006
POSTGRES_PORT=5432
REDIS_PORT=6379
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
GRAFANA_PORT=3002
PROMETHEUS_PORT=9090

# =============================================================================
# 服务 URL 配置 (Service URL Configuration)
# =============================================================================
# 内部服务 URL (Docker 网络)
QUANT_SYSTEM_URL=http://quant-system:8001
USER_MANAGEMENT_URL=http://user-management:3004
STRATEGY_DASHBOARD_URL=http://strategy-dashboard:3003
CONFIG_SERVICE_URL=http://config-service:3005

# 外部服务 URL (本地开发)
FRONTEND_URL=http://localhost:3000
UNIFIED_DASHBOARD_URL=http://localhost:3001

# =============================================================================
# WebSocket 配置 (WebSocket Configuration)
# =============================================================================
WEBSOCKET_ENABLED=true
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=3006
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_MAX_CONNECTIONS=1000

# =============================================================================
# 缓存配置 (Cache Configuration)
# =============================================================================
CACHE_TTL=3600
CACHE_TTL_DEFAULT=300
CACHE_TTL_HKMA=600
CACHE_TTL_SENTIMENT=180
CACHE_TTL_PERFORMANCE=3600
CACHE_PREFIX=cbsc
CACHE_MAX_SIZE=1000

# =============================================================================
# 文件上传配置 (File Upload Configuration)
# =============================================================================
UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE=52428800
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,csv,xlsx,xls,json

# =============================================================================
# 日志配置 (Logging Configuration)
# =============================================================================
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=10
LOG_ROTATION=daily

# =============================================================================
# 监控配置 (Monitoring Configuration)
# =============================================================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=30d
GRAFANA_ENABLED=true
GRAFANA_PORT=3002
GRAFANA_PASSWORD=your_grafana_admin_password
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30
MONITORING_RETENTION=7d

# =============================================================================
# 邮件配置 (Email Configuration)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_TLS=true
SMTP_SSL=false
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=CBSC System

# =============================================================================
# OAuth 认证配置 (OAuth Authentication)
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# 微信登录
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# =============================================================================
# 外部 API 配置 (External API Configuration)
# =============================================================================
# HKMA API (香港金管局)
HKMA_API_KEY=your_hkma_api_key
HKMA_API_URL=https://api.hkma.gov.hk
HKMA_RATE_LIMIT=100/minute

# 情绪分析 API
SENTIMENT_API_KEY=your_sentiment_api_key
SENTIMENT_API_URL=https://api.sentiment-analysis.com

# Yahoo Finance API
YAHOO_FINANCE_API_KEY=your_yahoo_finance_api_key

# 是否启用外部 API (演示模式可设为 false)
ENABLE_EXTERNAL_APIS=false
DEMO_MODE=false

# =============================================================================
# 速率限制配置 (Rate Limiting Configuration)
# =============================================================================
RATE_LIMIT_ENABLED=true
MAX_REQUESTS_PER_IP=1000
RATE_LIMIT_WINDOW=60
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_BURST=2000
RATE_LIMIT_STRICT=true

# =============================================================================
# 性能配置 (Performance Configuration)
# =============================================================================
WORKERS=4
WORKER_CONNECTIONS=1000
MAX_REQUESTS=10000
KEEP_ALIVE=2
MAX_WORKER_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65
GRACEFUL_SHUTDOWN_TIMEOUT=30

# =============================================================================
# SSL/TLS 配置 (SSL/TLS Configuration)
# =============================================================================
SSL_ENABLED=false
SSL_CERT_PATH=/app/ssl/cert.pem
SSL_KEY_PATH=/app/ssl/key.pem
SSL_CHAIN_PATH=/app/ssl/chain.pem

# =============================================================================
# 域名配置 (Domain Configuration)
# =============================================================================
DOMAIN=localhost
SUBDOMAIN_API=api.yourdomain.com
SUBDOMAIN_APP=app.yourdomain.com
SUBDOMAIN_ADMIN=admin.yourdomain.com
SUBDOMAIN_MONITORING=monitoring.yourdomain.com

# =============================================================================
# 备份配置 (Backup Configuration)
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=ap-southeast-1

# =============================================================================
# 通知配置 (Notification Configuration)
# =============================================================================
WEBHOOK_URL=https://hooks.slack.com/your/slack/webhook
NOTIFICATION_EMAIL=admin@yourdomain.com
ERROR_NOTIFICATION_ENABLED=true
ALERT_EMAIL=admin@yourdomain.com
SLACK_WEBHOOK_URL=your_slack_webhook_url
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# =============================================================================
# 合规配置 (Compliance Configuration)
# =============================================================================
AUDIT_LOG_ENABLED=true
AUDIT_RETENTION_YEARS=7
DATA_ENCRYPTION_ENABLED=true
GDPR_COMPLIANCE=true
PDPO_COMPLIANCE=true

# =============================================================================
# 功能开关 (Feature Flags)
# =============================================================================
ENABLE_MFA=true
ENABLE_RBAC=true
ENABLE_USER_PREFERENCES=true
ENABLE_REAL_TIME_DATA=true
ENABLE_STRATEGY_BACKTEST=true
ENABLE_RISK_MONITORING=true
ENABLE_WEBSOCKET_V2=true
ENABLE_BATCH_OPERATIONS=true
ENABLE_PERFORMANCE_ANALYTICS=true

# =============================================================================
# 认证配置 (Authentication Configuration)
# =============================================================================
AUTH_ENABLED=true
MAX_LOGIN_ATTEMPTS=10
LOCKOUT_DURATION=1800

# =============================================================================
# PostgreSQL 性能调优 (PostgreSQL Performance Tuning)
# =============================================================================
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB

# =============================================================================
# Redis 性能调优 (Redis Performance Tuning)
# =============================================================================
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# =============================================================================
# 第三方监控服务 (Third-party Monitoring Services)
# =============================================================================
NEW_RELIC_LICENSE_KEY=your_new_relic_key
SENTRY_DSN=your_sentry_dsn
PAGERDUTY_SERVICE_KEY=your_pagerduty_key

# =============================================================================
# 前端环境变量 (Frontend Environment Variables - Vite)
# =============================================================================
# 注意：前端环境变量必须以 VITE_ 开头
VITE_API_BASE_URL=http://localhost:3004/api
VITE_WS_URL=ws://localhost:3004/ws
VITE_APP_TITLE=CBSC 量化交易策略管理系统
VITE_APP_VERSION=1.0.0
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_ANALYTICS=false
VITE_ENVIRONMENT=development

# =============================================================================
# 开发环境特定配置 (Development Environment Only)
# =============================================================================
# 取消注释以下行用于开发环境
# ENVIRONMENT=development
# DEBUG=true
# LOG_LEVEL=DEBUG
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
# RATE_LIMIT_ENABLED=false
# SSL_ENABLED=false
# DEMO_MODE=true

# =============================================================================
# 测试环境配置 (Testing Environment Only)
# =============================================================================
# 取消注释以下行用于测试环境
# ENVIRONMENT=testing
# LOG_LEVEL=WARNING
# DATABASE_URL=postgresql://cbsc_test:test_password@localhost:5432/cbsc_test
# REDIS_URL=redis://localhost:6380/1
# POSTGRES_DB=cbsc_test
# POSTGRES_USER=cbsc_test
# POSTGRES_PASSWORD=test_password

# =============================================================================
# 安全提醒 (Security Reminders)
# =============================================================================
# 重要提醒：
# 1. 更改所有默认密码和密钥
# 2. 使用强密码和长随机密钥（至少 32 字符）
# 3. 定期轮换密钥和密码
# 4. 不要在版本控制中提交真实的密钥
# 5. 使用环境变量或密钥管理服务（如 AWS Secrets Manager、Azure Key Vault）
# 6. 启用 SSL/TLS 加密
# 7. 配置防火墙和安全组
# 8. 定期更新依赖包
# 9. 启用日志监控和告警
# 10. 实施备份和恢复策略
# 11. 生产环境必须修改所有包含 "change_this" 或 "your_" 的值

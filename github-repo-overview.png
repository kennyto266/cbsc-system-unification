    uid=4_3906 heading "What Makes This Different?" level="2"
    uid=4_3907 link "Permalink: What Makes This Different?" url="https://github.com/kennyto266/cbsc-system-unification#what-makes-this-different"
    uid=4_3908 StaticText "Traditional Development"
    uid=4_3909 StaticText "Claude Code PM System"
    uid=4_3910 StaticText "Context lost between sessions"
    uid=4_3911 StaticText "Persistent context"
    uid=4_3912 StaticText " across all work"
    uid=4_3913 StaticText "Serial task execution"
    uid=4_3914 StaticText "Parallel agents"
    uid=4_3915 StaticText " on independent tasks"
    uid=4_3916 StaticText ""Vibe coding" from memory"
    uid=4_3917 StaticText "Spec-driven"
    uid=4_3918 StaticText " with full traceability"
    uid=4_3919 StaticText "Progress hidden in branches"
    uid=4_3920 StaticText "Transparent audit trail"
    uid=4_3921 StaticText " in GitHub"
    uid=4_3922 StaticText "Manual task coordination"
    uid=4_3923 StaticText "Intelligent prioritization"
    uid=4_3924 StaticText " with "
    uid=4_3925 StaticText "/pm:next"
    uid=4_3926 heading "Why GitHub Issues?" level="2"
    uid=4_3927 link "Permalink: Why GitHub Issues?" url="https://github.com/kennyto266/cbsc-system-unification#why-github-issues"
    uid=4_3928 StaticText "Most Claude Code workflows operate in isolation – a single developer working with AI in their local environment. This creates a fundamental problem: "
    uid=4_3929 StaticText "AI-assisted development becomes a silo"
    uid=4_3930 StaticText "."
    uid=4_3931 StaticText "By using GitHub Issues as our database, we unlock something powerful:"
    uid=4_3932 heading "🤝 True Team Collaboration" level="3"
    uid=4_3933 link "Permalink: 🤝 True Team Collaboration" url="https://github.com/kennyto266/cbsc-system-unification#-true-team-collaboration"
    uid=4_3934 StaticText "Multiple Claude instances can work on the same project simultaneously"
    uid=4_3935 StaticText "Human developers see AI progress in real-time through issue comments"
    uid=4_3936 StaticText "Team members can jump in anywhere – the context is always visible"
    uid=4_3937 StaticText "Managers get transparency without interrupting flow"
    uid=4_3938 heading "🔄 Seamless Human-AI Handoffs" level="3"
    uid=4_3939 link "Permalink: 🔄 Seamless Human-AI Handoffs" url="https://github.com/kennyto266/cbsc-system-unification#-seamless-human-ai-handoffs"
    uid=4_3940 StaticText "AI can start a task, human can finish it (or vice versa)"
    uid=4_3941 StaticText "Progress updates are visible to everyone, not trapped in chat logs"
    uid=4_3942 StaticText "Code reviews happen naturally through PR comments"
    uid=4_3943 StaticText "No "what did the AI do?" meetings"
    uid=4_3944 heading "📈 Scalable Beyond Solo Work" level="3"
    uid=4_3945 link "Permalink: 📈 Scalable Beyond Solo Work" url="https://github.com/kennyto266/cbsc-system-unification#-scalable-beyond-solo-work"
    uid=4_3946 StaticText "Add team members without onboarding friction"
    uid=4_3947 StaticText "Multiple AI agents working in parallel on different issues"
    uid=4_3948 StaticText "Distributed teams stay synchronized automatically"
    uid=4_3949 StaticText "Works with existing GitHub workflows and tools"
    uid=4_3950 heading "🎯 Single Source of Truth" level="3"
    uid=4_3951 link "Permalink: 🎯 Single Source of Truth" url="https://github.com/kennyto266/cbsc-system-unification#-single-source-of-truth"
    uid=4_3952 StaticText "No separate databases or project management tools"
    uid=4_3953 StaticText "Issue state is the project state"
    uid=4_3954 StaticText "Comments are the audit trail"
    uid=4_3955 StaticText "Labels provide organization"
    uid=4_3956 StaticText "This isn't just a project management system – it's a "
    uid=4_3957 StaticText "collaboration protocol"
    uid=4_3958 StaticText " that lets humans and AI agents work together at scale, using infrastructure your team already trusts."
    uid=4_3959 heading "Core Principle: No Vibe Coding" level="2"
    uid=4_3960 link "Permalink: Core Principle: No Vibe Coding" url="https://github.com/kennyto266/cbsc-system-unification#core-principle-no-vibe-coding"
    uid=4_3961 StaticText "Every line of code must trace back to a specification."
    uid=4_3962 StaticText "We follow a strict 5-phase discipline:"
    uid=4_3963 StaticText "🧠 Brainstorm"
    uid=4_3964 StaticText " - Think deeper than comfortable"
    uid=4_3965 StaticText "📝 Document"
    uid=4_3966 StaticText " - Write specs that leave nothing to interpretation"
    uid=4_3967 StaticText "📐 Plan"
    uid=4_3968 StaticText " - Architect with explicit technical decisions"
    uid=4_3969 StaticText "⚡ Execute"
    uid=4_3970 StaticText " - Build exactly what was specified"
    uid=4_3971 StaticText "📊 Track"
    uid=4_3972 StaticText " - Maintain transparent progress at every step"
    uid=4_3973 StaticText "No shortcuts. No assumptions. No regrets."
    uid=4_3974 heading "System Architecture" level="2"
    uid=4_3975 link "Permalink: System Architecture" url="https://github.com/kennyto266/cbsc-system-unification#system-architecture"
    uid=4_3976 StaticText ".claude/
├── CLAUDE.md          # Always-on instructions (copy content to your project's CLAUDE.md file)
├── agents/            # Task-oriented agents (for context preservation)
├── commands/          # Command definitions
│   ├── context/       # Create, update, and prime context
│   ├── pm/            # ← Project management commands (this system)
│   └── testing/       # Prime and execute tests (edit this)
├── context/           # Project-wide context files
├── epics/             # ← PM's local workspace (place in .gitignore)
│   └── [epic-name]/   # Epic and related tasks
│       ├── epic.md    # Implementation plan
│       ├── [#].md     # Individual task files
│       └── updates/   # Work-in-progress updates
├── prds/              # ← PM's PRD files
├── rules/             # Place any rule files you'd like to reference here
└── scripts/           # Place any script files you'd like to use here
"
    uid=4_3977 button "Copy"
    uid=4_3978 heading "Workflow Phases" level="2"
    uid=4_3979 link "Permalink: Workflow Phases" url="https://github.com/kennyto266/cbsc-system-unification#workflow-phases"
    uid=4_3980 heading "1. Product Planning Phase" level="3"
    uid=4_3981 link "Permalink: 1. Product Planning Phase" url="https://github.com/kennyto266/cbsc-system-unification#1-product-planning-phase"
    uid=4_3982 StaticText "/pm:prd-new feature-name"
    uid=4_3983 button "Copy"
    uid=4_3984 StaticText "Launches comprehensive brainstorming to create a Product Requirements Document capturing vision, user stories, success criteria, and constraints."
    uid=4_3985 StaticText "Output:"
    uid=4_3986 StaticText " "
    uid=4_3987 StaticText ".claude/prds/feature-name.md"
    uid=4_3988 heading "2. Implementation Planning Phase" level="3"
    uid=4_3989 link "Permalink: 2. Implementation Planning Phase" url="https://github.com/kennyto266/cbsc-system-unification#2-implementation-planning-phase"
    uid=4_3990 StaticText "/pm:prd-parse feature-name"
    uid=4_3991 button "Copy"
    uid=4_3992 StaticText "Transforms PRD into a technical implementation plan with architectural decisions, technical approach, and dependency mapping."
    uid=4_3993 StaticText "Output:"
    uid=4_3994 StaticText " "
    uid=4_3995 StaticText ".claude/epics/feature-name/epic.md"
    uid=4_3996 heading "3. Task Decomposition Phase" level="3"
    uid=4_3997 link "Permalink: 3. Task Decomposition Phase" url="https://github.com/kennyto266/cbsc-system-unification#3-task-decomposition-phase"
    uid=4_3998 StaticText "/pm:epic-decompose feature-name"
    uid=4_3999 button "Copy"
    uid=4_4000 StaticText "Breaks epic into concrete, actionable tasks with acceptance criteria, effort estimates, and parallelization flags."
    uid=4_4001 StaticText "Output:"
    uid=4_4002 StaticText " "
    uid=4_4003 StaticText ".claude/epics/feature-name/[task].md"
    uid=4_4004 heading "4. GitHub Synchronization" level="3"

    uid=4_4107 heading "The Parallel Execution System" level="2"
    uid=4_4108 link "Permalink: The Parallel Execution System" url="https://github.com/kennyto266/cbsc-system-unification#the-parallel-execution-system"
    uid=4_4109 heading "Issues Aren't Atomic" level="3"
    uid=4_4110 link "Permalink: Issues Aren't Atomic" url="https://github.com/kennyto266/cbsc-system-unification#issues-arent-atomic"
    uid=4_4111 StaticText "Traditional thinking: One issue = One developer = One task"
    uid=4_4112 StaticText "Reality: One issue = Multiple parallel work streams"
    uid=4_4113 StaticText "A single "Implement user authentication" issue isn't one task. It's..."
    uid=4_4114 StaticText "Agent 1"
    uid=4_4115 StaticText ": Database tables and migrations"
    uid=4_4116 StaticText "Agent 2"
    uid=4_4117 StaticText ": Service layer and business logic"
    uid=4_4118 StaticText "Agent 3"
    uid=4_4119 StaticText ": API endpoints and middleware"
    uid=4_4120 StaticText "Agent 4"
    uid=4_4121 StaticText ": UI components and forms"
    uid=4_4122 StaticText "Agent 5"
    uid=4_4123 StaticText ": Test suites and documentation"
    uid=4_4124 StaticText "All running "
    uid=4_4125 StaticText "simultaneously"
    uid=4_4126 StaticText " in the same worktree."
    uid=4_4127 heading "The Math of Velocity" level="3"
    uid=4_4128 link "Permalink: The Math of Velocity" url="https://github.com/kennyto266/cbsc-system-unification#the-math-of-velocity"
    uid=4_4129 StaticText "Traditional Approach:"
    uid=4_4130 StaticText "Epic with 3 issues"
    uid=4_4131 StaticText "Sequential execution"
    uid=4_4132 StaticText "This System:"
    uid=4_4133 StaticText "Same epic with 3 issues"
    uid=4_4134 StaticText "Each issue splits into ~4 parallel streams"
    uid=4_4135 StaticText "12 agents working simultaneously"
    uid=4_4136 StaticText "We're not assigning agents to issues. We're "
    uid=4_4137 StaticText "leveraging multiple agents"
    uid=4_4138 StaticText " to ship faster."
    uid=4_4139 heading "Context Optimization" level="3"
    uid=4_4140 link "Permalink: Context Optimization" url="https://github.com/kennyto266/cbsc-system-unification#context-optimization"
    uid=4_4141 StaticText "Traditional single-thread approach:"
    uid=4_4142 StaticText "Main conversation carries ALL the implementation details"
    uid=4_4143 StaticText "Context window fills with database schemas, API code, UI components"
    uid=4_4144 StaticText "Eventually hits context limits and loses coherence"
    uid=4_4145 StaticText "Parallel agent approach:"
    uid=4_4146 StaticText "Main thread stays clean and strategic"
    uid=4_4147 StaticText "Each agent handles its own context in isolation"
    uid=4_4148 StaticText "Implementation details never pollute the main conversation"
    uid=4_4149 StaticText "Main thread maintains oversight without drowning in code"
    uid=4_4150 StaticText "Your main conversation becomes the conductor, not the orchestra."
    uid=4_4151 heading "GitHub vs Local: Perfect Separation" level="3"
    uid=4_4152 link "Permalink: GitHub vs Local: Perfect Separation" url="https://github.com/kennyto266/cbsc-system-unification#github-vs-local-perfect-separation"
    uid=4_4153 StaticText "What GitHub Sees:"
    uid=4_4154 StaticText "Clean, simple issues"
    uid=4_4155 StaticText "Progress updates"
    uid=4_4156 StaticText "Completion status"
    uid=4_4157 StaticText "What Actually Happens Locally:"
    uid=4_4158 StaticText "Issue #1234 explodes into 5 parallel agents"
    uid=4_4159 StaticText "Agents coordinate through Git commits"
    uid=4_4160 StaticText "Complex orchestration hidden from view"
    uid=4_4161 StaticText "GitHub doesn't need to know HOW the work got done – just that it IS done."
    uid=4_4162 heading "The Command Flow" level="3"
    uid=4_4163 link "Permalink: The Command Flow" url="https://github.com/kennyto266/cbsc-system-unification#the-command-flow"
    uid=4_4164 StaticText "#"
    uid=4_4165 StaticText " Analyze what can be parallelized"
    uid=4_4166 StaticText "
/pm:issue-analyze 1234

"
    uid=4_4167 StaticText "#"
    uid=4_4168 StaticText " Launch the swarm"
    uid=4_4169 StaticText "
/pm:epic-start memory-system

"
    uid=4_4170 StaticText "#"
    uid=4_4171 StaticText " Watch the magic"
    uid=4_4172 StaticText "
"
    uid=4_4173 StaticText "#"
    uid=4_4174 StaticText " 12 agents working across 3 issues"
    uid=4_4175 StaticText "
"
    uid=4_4176 StaticText "#"
    uid=4_4177 StaticText " All in: ../epic-memory-system/"
    uid=4_4178 StaticText "

"
    uid=4_4179 StaticText "#"
    uid=4_4180 StaticText " One clean merge when done"
    uid=4_4181 StaticText "
/pm:epic-merge memory-system"
    uid=4_4182 button "Copy"
    uid=4_4183 heading "Key Features & Benefits" level="2"
    uid=4_4184 link "Permalink: Key Features & Benefits" url="https://github.com/kennyto266/cbsc-system-unification#key-features--benefits"
    uid=4_4185 heading "🧠 Context Preservation" level="3"
    uid=4_4186 link "Permalink: 🧠 Context Preservation" url="https://github.com/kennyto266/cbsc-system-unification#-context-preservation"
    uid=4_4187 StaticText "Never lose project state again. Each epic maintains its own context, agents read from "
    uid=4_4188 StaticText ".claude/context/"
    uid=4_4189 StaticText ", and updates locally before syncing."
    uid=4_4190 heading "⚡ Parallel Execution" level="3"
    uid=4_4191 link "Permalink: ⚡ Parallel Execution" url="https://github.com/kennyto266/cbsc-system-unification#-parallel-execution"
    uid=4_4192 StaticText "Ship faster with multiple agents working simultaneously. Tasks marked "
    uid=4_4193 StaticText "parallel: true"
    uid=4_4194 StaticText " enable conflict-free concurrent development."
    uid=4_4195 heading "🔗 GitHub Native" level="3"
    uid=4_4196 link "Permalink: 🔗 GitHub Native" url="https://github.com/kennyto266/cbsc-system-unification#-github-native"
    uid=4_4197 StaticText "Works with tools your team already uses. Issues are the source of truth, comments provide history, and there is no dependency on the Projects API."
    uid=4_4198 heading "🤖 Agent Specialization" level="3"
    uid=4_4199 link "Permalink: 🤖 Agent Specialization" url="https://github.com/kennyto266/cbsc-system-unification#-agent-specialization"
    uid=4_4200 StaticText "Right tool for every job. Different agents for UI, API, and database work. Each reads requirements and posts updates automatically."
    uid=4_4201 heading "📊 Full Traceability" level="3"
    uid=4_4202 link "Permalink: 📊 Full Traceability" url="https://github.com/kennyto266/cbsc-system-unification#-full-traceability"
    uid=4_4203 StaticText "Every decision is documented. PRD → Epic → Task → Issue → Code → Commit. Complete audit trail from idea to production."
    uid=4_4204 heading "🚀 Developer Productivity" level="3"
    uid=4_4205 link "Permalink: 🚀 Developer Productivity" url="https://github.com/kennyto266/cbsc-system-unification#-developer-productivity"
    uid=4_4206 StaticText "Focus on building, not managing. Intelligent prioritization, automatic context loading, and incremental sync when ready."
    uid=4_4207 heading "Proven Results" level="2"
    uid=4_4208 link "Permalink: Proven Results" url="https://github.com/kennyto266/cbsc-system-unification#proven-results"
    uid=4_4209 StaticText "Teams using this system report:"
    uid=4_4210 StaticText "89% less time"
    uid=4_4211 StaticText " lost to context switching – you'll use "
    uid=4_4212 StaticText "/compact"
    uid=4_4213 StaticText " and "
    uid=4_4214 StaticText "/clear"
    uid=4_4215 StaticText " a LOT less"
    uid=4_4216 StaticText "5-8 parallel tasks"
    uid=4_4217 StaticText " vs 1 previously – editing/testing multiple files at the same time"
    uid=4_4218 StaticText "75% reduction"
    uid=4_4219 StaticText " in bug rates – due to the breaking down features into detailed tasks"
    uid=4_4220 StaticText "Up to 3x faster"
    uid=4_4221 StaticText " feature delivery – based on feature size and complexity"
    uid=4_4222 heading "Example Flow" level="2"
    uid=4_4223 link "Permalink: Example Flow" url="https://github.com/kennyto266/cbsc-system-unification#example-flow"
    uid=4_4224 StaticText "#"
    uid=4_4225 StaticText " Start a new feature"
    uid=4_4226 StaticText "
/pm:prd-new memory-system

"
    uid=4_4227 StaticText "#"
    uid=4_4228 StaticText " Review and refine the PRD..."
    uid=4_4229 StaticText "

"
    uid=4_4230 StaticText "#"
    uid=4_4231 StaticText " Create implementation plan"
    uid=4_4232 StaticText "
/pm:prd-parse memory-system

"
    uid=4_4233 StaticText "#"
    uid=4_4234 StaticText " Review the epic..."
    uid=4_4235 StaticText "

"
    uid=4_4236 StaticText "#"
    uid=4_4237 StaticText " Break into tasks and push to GitHub"
    uid=4_4238 StaticText "
/pm:epic-oneshot memory-system
"
    uid=4_4239 StaticText "#"
    uid=4_4240 StaticText " Creates issues: #1234 (epic), #1235, #1236 (tasks)"
    uid=4_4241 StaticText "

"
    uid=4_4242 StaticText "#"
    uid=4_4243 StaticText " Start development on a task"
    uid=4_4244 StaticText "
/pm:issue-start 1235
"
    uid=4_4245 StaticText "#"
    uid=4_4246 StaticText " Agent begins work, maintains local progress"
    uid=4_4247 StaticText "

"
    uid=4_4248 StaticText "#"
    uid=4_4249 StaticText " Sync progress to GitHub"
    uid=4_4250 StaticText "
/pm:issue-sync 1235
"
    uid=4_4251 StaticText "#"
    uid=4_4252 StaticText " Updates posted as issue comments"
    uid=4_4253 StaticText "

"
    uid=4_4254 StaticText "#"
    uid=4_4255 StaticText " Check overall status"
    uid=4_4256 StaticText "
/pm:epic-show memory-system"
    uid=4_4257 button "Copy"
    uid=4_4258 heading "Get Started Now" level="2"
    uid=4_4259 link "Permalink: Get Started Now" url="https://github.com/kennyto266/cbsc-system-unification#get-started-now"
    uid=4_4260 heading "Quick Setup (2 minutes)" level="3"
    uid=4_4261 link "Permalink: Quick Setup (2 minutes)" url="https://github.com/kennyto266/cbsc-system-unification#quick-setup-2-minutes"
    uid=4_4262 StaticText "Install this repository into your project"
    uid=4_4263 StaticText ":"
    uid=4_4264 heading "Unix/Linux/macOS" level="4"
    uid=4_4265 link "Permalink: Unix/Linux/macOS" url="https://github.com/kennyto266/cbsc-system-unification#unixlinuxmacos"
    uid=4_4266 StaticText "cd"
    uid=4_4267 StaticText " path/to/your/project/
curl -sSL https://automaze.io/ccpm/install "
    uid=4_4268 StaticText "|"
    uid=4_4269 StaticText " bash
"
    uid=4_4270 StaticText "#"
    uid=4_4271 StaticText " or: wget -qO- https://automaze.io/ccpm/install | bash"
    uid=4_4272 button "Copy"
    uid=4_4273 heading "Windows (PowerShell)" level="4"
    uid=4_4274 link "Permalink: Windows (PowerShell)" url="https://github.com/kennyto266/cbsc-system-unification#windows-powershell"
    uid=4_4275 StaticText "cd"
    uid=4_4276 StaticText " path/to/your/project/
iwr -useb https://automaze.io/ccpm/install "
    uid=4_4277 StaticText "|"
    uid=4_4278 StaticText " iex"
    uid=4_4279 button "Copy"
    uid=4_4280 StaticText "⚠️"
    uid=4_4281 StaticText "IMPORTANT"
    uid=4_4282 StaticText ": If you already have a "
    uid=4_4283 StaticText ".claude"
    uid=4_4284 StaticText " directory, clone this repository to a different directory and copy the contents of the cloned "
    uid=4_4285 StaticText ".claude"
    uid=4_4286 StaticText " directory to your project's "
    uid=4_4287 StaticText ".claude"
    uid=4_4288 StaticText " directory."
    uid=4_4289 StaticText "See full/other installation options in the "
    uid=4_4290 link "installation guide ›" url="https://github.com/automazeio/ccpm/tree/main/install"
      uid=4_4291 StaticText "installation guide ›"
    uid=4_4292 StaticText "Initialize the PM system"
    uid=4_4293 StaticText ":"
    uid=4_4294 StaticText "/pm:init"
    uid=4_4295 button "Copy"
    uid=4_4296 StaticText "This command will:"
    uid=4_4297 StaticText "Install GitHub CLI (if needed)"
    uid=4_4298 StaticText "Authenticate with GitHub"
    uid=4_4299 StaticText "Install "
    uid=4_4300 link "gh-sub-issue extension" url="https://github.com/yahsan2/gh-sub-issue"
      uid=4_4301 StaticText "gh-sub-issue extension"
    uid=4_4302 StaticText " for proper parent-child relationships"
    uid=4_4303 StaticText "Create required directories"
    uid=4_4304 StaticText "Update .gitignore"
    uid=4_4305 StaticText "Create "
    uid=4_4306 StaticText "CLAUDE.md"
    uid=4_4307 StaticText " with your repository information"
    uid=4_4308 StaticText "/init include rules from .claude/CLAUDE.md"
    uid=4_4309 button "Copy"
    uid=4_4310 StaticText "If you already have a "
    uid=4_4311 StaticText "CLAUDE.md"
    uid=4_4312 StaticText " file, run: "
    uid=4_4313 StaticText "/re-init"
    uid=4_4314 StaticText " to update it with important rules from "
    uid=4_4315 StaticText ".claude/CLAUDE.md"
    uid=4_4316 StaticText "."
    uid=4_4317 StaticText "Prime the system"
    uid=4_4318 StaticText ":"
    uid=4_4319 StaticText "/context:create"
    uid=4_4320 button "Copy"
    uid=4_4321 heading "Start Your First Feature" level="3"
    uid=4_4322 link "Permalink: Start Your First Feature" url="https://github.com/kennyto266/cbsc-system-unification#start-your-first-feature"
    uid=4_4323 StaticText "/pm:prd-new your-feature-name"
    uid=4_4324 button "Copy"
    uid=4_4325 StaticText "Watch as structured planning transforms into shipped code."
    uid=4_4326 heading "Local vs Remote" level="2"
    uid=4_4327 link "Permalink: Local vs Remote" url="https://github.com/kennyto266/cbsc-system-unification#local-vs-remote"
    uid=4_4328 StaticText "Operation"
    uid=4_4329 StaticText "Local"
    uid=4_4330 StaticText "GitHub"
    uid=4_4331 StaticText "PRD Creation"
    uid=4_4332 StaticText "✅"
    uid=4_4333 StaticText "—"
    uid=4_4334 StaticText "Implementation Planning"
    uid=4_4335 StaticText "✅"
    uid=4_4336 StaticText "—"
    uid=4_4337 StaticText "Task Breakdown"
    uid=4_4338 StaticText "✅"
    uid=4_4339 StaticText "✅ (sync)"
    uid=4_4340 StaticText "Execution"
    uid=4_4341 StaticText "✅"
    uid=4_4342 StaticText "—"
    uid=4_4343 StaticText "Status Updates"
    uid=4_4344 StaticText "✅"
    uid=4_4345 StaticText "✅ (sync)"
    uid=4_4346 StaticText "Final Deliverables"
    uid=4_4347 StaticText "—"
    uid=4_4348 StaticText "✅"
    uid=4_4349 heading "Technical Notes" level="2"
    uid=4_4350 link "Permalink: Technical Notes" url="https://github.com/kennyto266/cbsc-system-unification#technical-notes"
    uid=4_4351 heading "GitHub Integration" level="3"
    uid=4_4352 link "Permalink: GitHub Integration" url="https://github.com/kennyto266/cbsc-system-unification#github-integration"
    uid=4_4353 StaticText "Uses "
    uid=4_4354 StaticText "gh-sub-issue extension"
    uid=4_4355 StaticText " for proper parent-child relationships"
    uid=4_4356 StaticText "Falls back to task lists if extension not installed"
    uid=4_4357 StaticText "Epic issues track sub-task completion automatically"
    uid=4_4358 StaticText "Labels provide additional organization ("
    uid=4_4359 StaticText "epic:feature"
    uid=4_4360 StaticText ", "
    uid=4_4361 StaticText "task:feature"
    uid=4_4362 StaticText ")"
    uid=4_4363 heading "File Naming Convention" level="3"
    uid=4_4364 link "Permalink: File Naming Convention" url="https://github.com/kennyto266/cbsc-system-unification#file-naming-convention"
    uid=4_4365 StaticText "Tasks start as "
    uid=4_4366 StaticText "001.md"
    uid=4_4367 StaticText ", "
    uid=4_4368 StaticText "002.md"
    uid=4_4369 StaticText " during decomposition"
    uid=4_4370 StaticText "After GitHub sync, renamed to "
    uid=4_4371 StaticText "{issue-id}.md"
    uid=4_4372 StaticText " (e.g., "
    uid=4_4373 StaticText "1234.md"
    uid=4_4374 StaticText ")"
    uid=4_4375 StaticText "Makes it easy to navigate: issue #1234 = file "
    uid=4_4376 StaticText "1234.md"
    uid=4_4377 heading "Design Decisions" level="3"
    uid=4_4378 link "Permalink: Design Decisions" url="https://github.com/kennyto266/cbsc-system-unification#design-decisions"
    uid=4_4379 StaticText "Intentionally avoids GitHub Projects API complexity"
    uid=4_4380 StaticText "All commands operate on local files first for speed"
    uid=4_4381 StaticText "Synchronization with GitHub is explicit and controlled"
    uid=4_4382 StaticText "Worktrees provide clean git isolation for parallel work"
    uid=4_4383 StaticText "GitHub Projects can be added separately for visualization"
    uid=4_4384 heading "Support This Project" level="2"
    uid=4_4385 link "Permalink: Support This Project" url="https://github.com/kennyto266/cbsc-system-unification#support-this-project"
    uid=4_4386 StaticText "Claude Code PM was developed at "

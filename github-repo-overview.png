    uid=4_3835 heading "Claude Code workflow to ship faster better using spec-driven development, GitHub issues, Git worktrees, and multiple AI agents running in parallel." level="3"
    uid=4_3836 link "Permalink: Claude Code workflow to ship fasterbetter using spec-driven development, GitHub issues, Git worktrees, and multiple AI agents running in parallel." url="https://github.com/kennyto266/cbsc-system-unification#claude-code-workflow-to-ship-faster-better-using-spec-driven-development-github-issues-git-worktrees-and-multiple-ai-agents-running-in-parallel"

{
  "api": {
    "host": "0.0.0.0",
    "port": 3004,
    "workers": 4,
    "reload": false,
    "access_log": true
  },
  "database": {
    "url": "${DATABASE_URL}",
    "pool_size": 20,
    "max_overflow": 30,
    "pool_timeout": 30
  },
  "redis": {
    "url": "${REDIS_URL}",
    "max_connections": 100
  },
  "security": {
    "cors_origins": [
      "${FRONTEND_URL}"
    ],
    "jwt_secret_key": "${JWT_SECRET}",
    "jwt_algorithm": "HS256",
    "jwt_expiration_hours": 24
  },
  "monitoring": {
    "enable_metrics": true,
    "metrics_port": 9090,
    "log_level": "INFO"
  }
}
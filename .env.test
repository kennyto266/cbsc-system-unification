# =============================================================================
# CBSC 系统测试环境配置
# =============================================================================
# 此文件用于自动化测试和集成测试
# 最后更新: 2025-01-04
# =============================================================================

# =============================================================================
# 系统基础配置
# =============================================================================
ENVIRONMENT=testing
APP_NAME=CBSC Quant Trading System
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=WARNING

# =============================================================================
# 数据库配置 (使用独立的测试数据库)
# =============================================================================
DATABASE_URL=postgresql://cbsc_test:test_password@localhost:5432/cbsc_test
POSTGRES_DB=cbsc_test
POSTGRES_USER=cbsc_test
POSTGRES_PASSWORD=test_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# =============================================================================
# Redis 配置 (使用独立的测试数据库)
# =============================================================================
REDIS_URL=redis://localhost:6379/1
REDIS_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

REDIS_POOL_SIZE=5
REDIS_MAX_CONNECTIONS=20

# =============================================================================
# InfluxDB 配置 (测试环境)
# =============================================================================
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=test_token_change_in_production
INFLUXDB_ORG=cbsc-test
INFLUXDB_BUCKET=market_data_test
INFLUXDB_USERNAME=cbsc_test
INFLUXDB_PASSWORD=test_password_change_in_production

# =============================================================================
# API 配置
# =============================================================================
API_HOST=127.0.0.1
API_PORT=3004
API_PREFIX=/api/v1
API_VERSION=v1

API_WORKERS=1
API_RATE_LIMIT_DEFAULT=10000/minute
API_RATE_LIMIT_BURST=1000
API_RATE_LIMIT_AUTH=10000/minute

# =============================================================================
# 安全配置
# =============================================================================
JWT_SECRET=test_jwt_secret_for_testing_only_minimum_32_characters
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

SECRET_KEY=test_secret_key_for_testing_only_minimum_32_characters
REFRESH_SECRET_KEY=test_refresh_secret_key_minimum_32_characters

SESSION_SECRET=test_session_secret_key_minimum_32_characters
SESSION_TIMEOUT=600
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true

ENCRYPTION_KEY=test_encryption_key_32_bytes_for_testing
AES256_KEY=test_aes256_key_for_testing_only

# =============================================================================
# CORS 配置 (测试环境)
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_HEADERS=Content-Type,Authorization,X-Requested-With

# =============================================================================
# 服务端口配置
# =============================================================================
FRONTEND_PORT=3000
UNIFIED_DASHBOARD_PORT=3001
API_GATEWAY_PORT=8000
USER_MANAGEMENT_PORT=3004
STRATEGY_DASHBOARD_PORT=3003
CONFIG_SERVICE_PORT=3005
WEBSOCKET_PORT=3006
POSTGRES_PORT=5432
REDIS_PORT=6379
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
GRAFANA_PORT=3002
PROMETHEUS_PORT=9090

# =============================================================================
# 服务 URL 配置
# =============================================================================
QUANT_SYSTEM_URL=http://localhost:8001
USER_MANAGEMENT_URL=http://localhost:3004
STRATEGY_DASHBOARD_URL=http://localhost:3003
CONFIG_SERVICE_URL=http://localhost:3005
FRONTEND_URL=http://localhost:3000
UNIFIED_DASHBOARD_URL=http://localhost:3001

# =============================================================================
# WebSocket 配置
# =============================================================================
WEBSOCKET_ENABLED=true
WEBSOCKET_HOST=127.0.0.1
WEBSOCKET_PORT=3006
WEBSOCKET_HEARTBEAT_INTERVAL=10
WEBSOCKET_MAX_CONNECTIONS=50

# =============================================================================
# 缓存配置
# =============================================================================
CACHE_TTL=60
CACHE_TTL_DEFAULT=30
CACHE_TTL_HKMA=60
CACHE_TTL_SENTIMENT=30
CACHE_TTL_PERFORMANCE=120
CACHE_PREFIX=cbsc_test
CACHE_MAX_SIZE=100

# =============================================================================
# 文件上传配置
# =============================================================================
UPLOAD_PATH=/tmp/cbsc_test_uploads
MAX_UPLOAD_SIZE=10485760
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,csv,json

# =============================================================================
# 日志配置
# =============================================================================
LOG_FORMAT=json
LOG_FILE_PATH=/tmp/cbsc_test.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=3
LOG_ROTATION=daily

# =============================================================================
# 监控配置
# =============================================================================
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=1d
GRAFANA_ENABLED=false
GRAFANA_PORT=3002
GRAFANA_PASSWORD=test123
METRICS_ENABLED=false
HEALTH_CHECK_INTERVAL=10
MONITORING_RETENTION=1d

# =============================================================================
# 邮件配置 (测试环境 - 使用 mock)
# =============================================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=false
SMTP_SSL=false
FROM_EMAIL=test@cbsc-test.local
FROM_NAME=CBSC Test

# =============================================================================
# OAuth 认证配置 (测试环境 - 使用 mock)
# =============================================================================
GOOGLE_CLIENT_ID=test_google_client_id
GOOGLE_CLIENT_SECRET=test_google_client_secret
GITHUB_CLIENT_ID=test_github_client_id
GITHUB_CLIENT_SECRET=test_github_client_secret
WECHAT_APP_ID=test_wechat_app_id
WECHAT_APP_SECRET=test_wechat_app_secret

# =============================================================================
# 外部 API 配置 (测试环境 - Mock 数据)
# =============================================================================
HKMA_API_KEY=test_hkma_api_key
HKMA_API_URL=https://api.hkma.gov.hk
HKMA_RATE_LIMIT=1000/minute

SENTIMENT_API_KEY=test_sentiment_api_key
SENTIMENT_API_URL=https://api.sentiment-analysis.com

YAHOO_FINANCE_API_KEY=test_yahoo_finance_api_key

ENABLE_EXTERNAL_APIS=false
DEMO_MODE=true

# =============================================================================
# 速率限制配置 (测试环境 - 宽松限制)
# =============================================================================
RATE_LIMIT_ENABLED=false
MAX_REQUESTS_PER_IP=100000
RATE_LIMIT_WINDOW=60
RATE_LIMIT_PER_MINUTE=100000
RATE_LIMIT_BURST=10000
RATE_LIMIT_STRICT=false

# =============================================================================
# 性能配置
# =============================================================================
WORKERS=1
WORKER_CONNECTIONS=50
MAX_REQUESTS=500
KEEP_ALIVE=2
MAX_WORKER_CONNECTIONS=50
KEEPALIVE_TIMEOUT=30
GRACEFUL_SHUTDOWN_TIMEOUT=5

# =============================================================================
# SSL/TLS 配置 (测试环境 - 禁用)
# =============================================================================
SSL_ENABLED=false
SSL_CERT_PATH=
SSL_KEY_PATH=
SSL_CHAIN_PATH=

# =============================================================================
# 域名配置
# =============================================================================
DOMAIN=localhost
SUBDOMAIN_API=localhost
SUBDOMAIN_APP=localhost
SUBDOMAIN_ADMIN=localhost
SUBDOMAIN_MONITORING=localhost

# =============================================================================
# 备份配置
# =============================================================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=1
BACKUP_PATH=/tmp/cbsc_test_backups
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=

# =============================================================================
# 通知配置
# =============================================================================
WEBHOOK_URL=
NOTIFICATION_EMAIL=test@localhost
ERROR_NOTIFICATION_ENABLED=false
ALERT_EMAIL=test@localhost
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# 合规配置
# =============================================================================
AUDIT_LOG_ENABLED=true
AUDIT_RETENTION_YEARS=1
DATA_ENCRYPTION_ENABLED=false
GDPR_COMPLIANCE=false
PDPO_COMPLIANCE=false

# =============================================================================
# 功能开关
# =============================================================================
ENABLE_MFA=false
ENABLE_RBAC=false
ENABLE_USER_PREFERENCES=true
ENABLE_REAL_TIME_DATA=true
ENABLE_STRATEGY_BACKTEST=true
ENABLE_RISK_MONITORING=true
ENABLE_WEBSOCKET_V2=true
ENABLE_BATCH_OPERATIONS=true
ENABLE_PERFORMANCE_ANALYTICS=true

# =============================================================================
# 认证配置
# =============================================================================
AUTH_ENABLED=true
MAX_LOGIN_ATTEMPTS=1000
LOCKOUT_DURATION=60

# =============================================================================
# PostgreSQL 性能调优 (测试环境 - 降低配置)
# =============================================================================
POSTGRES_SHARED_BUFFERS=32MB
POSTGRES_EFFECTIVE_CACHE_SIZE=64MB

# =============================================================================
# Redis 性能调优 (测试环境 - 降低配置)
# =============================================================================
REDIS_MAXMEMORY=32mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# =============================================================================
# 第三方监控服务
# =============================================================================
NEW_RELIC_LICENSE_KEY=
SENTRY_DSN=
PAGERDUTY_SERVICE_KEY=

# =============================================================================
# 前端环境变量
# =============================================================================
VITE_API_BASE_URL=http://localhost:3004/api
VITE_WS_URL=ws://localhost:3004/ws
VITE_APP_TITLE=CBSC 量化交易策略管理系统 (测试环境)
VITE_APP_VERSION=1.0.0-test
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_ANALYTICS=true
VITE_ENVIRONMENT=test

# =============================================================================
# 测试专用配置
# =============================================================================
# 测试数据库会自动创建和销毁
TEST_DATABASE_AUTO_CREATE=true
TEST_DATABASE_AUTO_DROP=true

# 测试超时配置 (秒)
TEST_REQUEST_TIMEOUT=30
TEST_DB_CONNECTION_TIMEOUT=10

# Mock 外部服务
USE_MOCK_EXTERNAL_SERVICES=true
MOCK_DATA_PATH=./tests/mock_data

# 并发测试配置
TEST_MAX_WORKERS=4
TEST_PARALLEL_TESTS=true

# Risk Management API v2 Environment Configuration
# ==================================================

# API Configuration
API_TITLE=CBSC Risk Management API
API_VERSION=2.0.0
DEBUG=false

# Server Configuration
HOST=0.0.0.0
PORT=8002
RELOAD=false

# Database Configuration
DATABASE_URL=sqlite:///./risk_management.db
# For PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/risk_management

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Risk Engine Configuration
RISK_CALCULATION_INTERVAL=60
VAR_CONFIDENCE_LEVELS=[0.95, 0.99]
ES_CONFIDENCE_LEVELS=[0.95, 0.99]
VOLATILITY_WINDOWS=[21, 63, 252]
MAX_DRAWDOWN_WINDOW=252

# Alert Configuration
ALERT_ENABLED=true
ALERT_COOLDOWN_PERIOD=300

# WebSocket Configuration
WEBSOCKET_HOST=0.0.0.0
WEBSOCKET_PORT=8003
WEBSOCKET_MAX_CONNECTIONS=1000

# Dynamic Adjustment Configuration
DYNAMIC_ADJUSTMENT_ENABLED=true
VOLATILITY_TARGET=0.15
REBALANCE_THRESHOLD=0.05

# InfluxDB Configuration
INFLUXDB_HOST=localhost
INFLUXDB_PORT=8086
INFLUXDB_DATABASE=risk_metrics
INFLUXDB_USERNAME=
INFLUXDB_PASSWORD=

# Rate Limiting
RATE_LIMITS={"default": "100/hour", "alerts": "50/hour", "reports": "20/hour", "adjustments": "20/hour"}

# Cache Configuration
CACHE_TTL=300

# File Storage
REPORTS_DIR=./reports

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/risk_api.log

# CORS Configuration
CORS_ORIGINS=*
# For production, specify specific origins:
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=*

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Security
ALLOWED_HOSTS=*
MAX_REQUEST_SIZE=10485760

# CBSC Integration
CBSC_API_URL=http://localhost:3003
CBSC_API_TIMEOUT=30

# Feature Flags
ENABLE_REAL_TIME_MONITORING=true
ENABLE_STRESS_TESTING=true
ENABLE_RECOMMENDATIONS=true

# Email Configuration (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

# Webhook Configuration (for alerts)
WEBHOOK_SECRET=your-webhook-secret

# AWS Configuration (if using S3 for reports)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=risk-reports

# Azure Configuration (if using Azure Blob Storage)
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER=risk-reports

# Google Cloud Configuration (if using GCS)
GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json
GCS_BUCKET=risk-reports
{
  "name": "ai-strategy-assistant",
  "displayName": "AI Strategy Assistant",
  "description": "Create quantitative trading strategies with GLM 4.7 AI",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Penguin8n/codex-ai-strategy-tool.git"
  },
  "bugs": {
    "url": "https://github.com/Penguin8n/codex-ai-strategy-tool/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Notebooks"
  ],
  "activationEvents": [
    "onCommand:aiStrategy.createNotebook",
    "onCommand:aiStrategy.openChat",
    "onCommand:aiStrategy.insertIntoNotebook",
    "onCommand:aiStrategy.configureApiKey"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiStrategy.createNotebook",
        "title": "Create Strategy Notebook",
        "category": "AI Strategy"
      },
      {
        "command": "aiStrategy.openChat",
        "title": "Open AI Chat",
        "category": "AI Strategy"
      },
      {
        "command": "aiStrategy.insertIntoNotebook",
        "title": "Insert Strategy into Notebook",
        "category": "AI Strategy"
      },
      {
        "command": "aiStrategy.configureApiKey",
        "title": "Configure GLM API Key",
        "category": "AI Strategy"
      }
    ],
    "configuration": {
      "title": "AI Strategy Assistant",
      "properties": {
        "aiStrategy.glmApiKey": {
          "type": "string",
          "default": "",
          "description": "Your GLM API Key from Zhipu AI",
          "order": 1
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiStrategySidebar",
          "title": "AI Strategy",
          "icon": "assets/ai-icon.svg"
        }
      ]
    },
    "views": {
      "aiStrategySidebar": [
        {
          "id": "aiChatView",
          "name": "AI Chat",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "jest src/test/"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/vscode": "^1.107.0",
    "@vscode/test-electron": "^2.5.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}

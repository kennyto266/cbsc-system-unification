                  uid=6_1817 ignored
                    uid=6_1818 generic description="import marimo as mo if not data_exists: return mo.md("⚠️ 請確保CBSC數據文件存在後再繼續"), None, None, None rsi_period = mo.ui.slider(5, 50, value=14, label="RSI 週期") sentiment_threshold = mo.ui.slider(0.1, 1.0, value=0.7, step=0.05, label="情緒閾值") ma_short = mo.ui.slider(5, 30, value=10, label="短期均線週期") ma_long = mo.ui.slider(20, 100, value=30, label="長期均線週期")"
                      uid=6_1819 ignored
                        uid=6_1820 StaticText "import marimo as mo"

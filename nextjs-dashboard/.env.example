# Next.js環境變量示例
# 複製此文件為 .env.local 並填寫實際值

# NextAuth配置
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# 數據庫配置
DATABASE_URL=postgresql://username:password@localhost:5432/cbsc_dashboard

# Redis配置
REDIS_URL=redis://localhost:6379

# API配置
API_BASE_URL=http://localhost:3004
API_SECRET_KEY=your-api-secret-key

# WebSocket配置
NEXT_PUBLIC_WS_URL=ws://localhost:3004

# CBSC API配置
CBSC_API_URL=https://api.cbsc.com
CBSC_API_KEY=your-cbsc-api-key
CBSC_API_SECRET=your-cbsc-api-secret

# 市場數據提供商
MARKET_DATA_API_KEY=your-market-data-api-key
MARKET_DATA_URL=https://api.marketdata.com

# 第三方服務
SENTRY_DSN=your-sentry-dsn
GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# 郵件服務
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# 文件存儲
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket

# 安全配置
ENCRYPTION_KEY=your-32-character-encryption-key
JWT_SECRET=your-jwt-secret-key

# 功能開關
ENABLE_ANALYTICS=true
ENABLE_MARKET_DATA=true
ENABLE_CBBC=true
ENABLE_RISK_ANALYSIS=true
ENABLE_BACKTEST=true
ENABLE_WEBSOCKET=true

# 緩存配置
CACHE_TTL=3600
QUERY_CACHE_TIME=5
MUTATION_CACHE_TIME=0

# 開發配置
NODE_ENV=development
LOG_LEVEL=debug
ENABLE_DEBUG_MODE=true

# 生產配置
# NODE_ENV=production
# LOG_LEVEL=info
# ENABLE_DEBUG_MODE=false
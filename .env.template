# Hong Kong Stock AI Agent System Environment Configuration Template
# Copy this file to .env and fill in actual values securely

# Cursor API Key (required)
# IMPORTANT: Do not hardcode the API key here. Use the secure credential manager:
# python -c "from src.security.secure_credential_manager import store_telegram_token; store_telegram_token('YOUR_TOKEN_HERE')"
CURSOR_API_KEY=your_cursor_api_key_here

# Stock Data API Configuration
STOCK_API_BASE_URL=http://18.180.162.113:9191

# Dashboard Configuration
DASHBOARD_PORT=8080

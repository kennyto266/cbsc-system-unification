TELEGRAM_BOT_TOKEN=USE_SECURE_MANAGER
TG_ALLOWED_USER_IDS=1005293427
# Allow group chats (add group chat IDs if needed, negative numbers for groups)
TG_ALLOWED_CHAT_IDS=
# Bot Owner User ID (for admin commands)
BOT_OWNER_USER_ID=1005293427

# Stock API Configuration
STOCK_API_URL=http://18.180.162.113:9191/inst/getInst
STOCK_API_TIMEOUT=10

# Security Configuration
# Master password for credential encryption (set via environment variable)
# CREDENTIAL_MASTER_PASSWORD=your_secure_master_password_here


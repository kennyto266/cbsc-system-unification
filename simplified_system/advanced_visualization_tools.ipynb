    "## 📊 自定義圖表模板 Custom Chart Templates\n",
    "\n",
    "### 專業量化分析模板庫"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ===================== 自定義圖表模板 Custom Chart Templates =====================\n",
    "\n",
    "class QuantitativeChartTemplates:\n",
    "    \"\"\"專業量化分析圖表模板\n",
    "    \n",
    "    Professional quantitative analysis chart templates\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        # Quantitative color palette\n",
    "        self.colors = {\n",
    "            'primary': '#1f77b4',\n",
    "            'success': '#2ca02c',\n",
    "            'danger': '#d62728',\n",
    "            'warning': '#ff7f0e',\n",
    "            'info': '#17becf',\n",
    "            'dark': '#7f7f7f',\n",
    "            'light': '#e377c2',\n",
    "            'bull': '#00d084',   # 綠色 - 上漲\n",
    "            'bear': '#ff4757'    # 紅色 - 下跌\n",
    "        }\n",
    "        \n",
    "        # Chart templates configuration\n",
    "        self.template_config = {\n",
    "            'theme': 'plotly_white',\n",
    "            'font_family': 'Arial, SimHei',\n",
    "            'font_size': 12,\n",
    "            'margin': dict(l=60, r=30, t=50, b=60),\n",
    "            'legend': dict(orientation=\"h\", yanchor=\"bottom\", y=1.02, xanchor=\"right\", x=1)\n",
    "        }\n",
    "    \n",
    "    def candlestick_chart(self, df, title=\"股價K線圖\", volume=True, indicators=None):\n",
    "        \"\"\"專業K線圖模板\n",
    "        \n",
    "        Professional candlestick chart template\n",
    "        \"\"\"\n",
    "        # Create subplot with price and volume\n",
    "        rows = 2 if volume else 1\n",
    "        fig = make_subplots(\n",
    "            rows=rows,\n",
    "            cols=1,\n",
    "            shared_xaxes=True,\n",
    "            vertical_spacing=0.02,\n",
    "            subplot_titles=(title, \"成交量\" if volume else None),\n",
    "            row_width=[0.2, 0.7] if volume else [0.2]\n",
    "        )\n",
    "        \n",
    "        # Candlestick chart\n",
    "        fig.add_trace(\n",
    "            go.Candlestick(\n",
    "                x=df.index,\n",
    "                open=df['Open'],\n",
    "                high=df['High'],\n",
    "                low=df['Low'],\n",
    "                close=df['Close'],\n",
    "                name=\"股價\",\n",
    "                increasing_line_color=self.colors['bull'],\n",
    "                decreasing_line_color=self.colors['bear']\n",
    "            ),\n",
    "            row=1, col=1\n",
    "        )\n",
    "        \n",
    "        # Add technical indicators if provided\n",
    "        if indicators:\n",
    "            for name, values in indicators.items():\n",
    "                fig.add_trace(\n",
    "                    go.Scatter(\n",
    "                        x=df.index,\n",
    "                        y=values,\n",
    "                        mode='lines',\n",
    "                        name=name,\n",
    "                        line=dict(width=2)\n",
    "                    ),\n",
    "                    row=1, col=1\n",
    "                )\n",
    "        \n",
    "        # Volume chart\n",
    "        if volume and 'Volume' in df.columns:\n",
    "            colors = [self.colors['bull'] if close >= open else self.colors['bear'] \n",
    "                     for close, open in zip(df['Close'], df['Open'])]\n",
    "            \n",
    "            fig.add_trace(\n",
    "                go.Bar(\n",
    "                    x=df.index,\n",
    "                    y=df['Volume'],\n",
    "                    name=\"成交量\",\n",
    "                    marker_color=colors\n",
    "                ),\n",
    "                row=2, col=1\n",
    "            )\n",
    "        \n",
    "        # Update layout\n",
    "        fig.update_layout(\n",
    "            template=self.template_config['theme'],\n",
    "            title=dict(text=title, x=0.5),\n",
    "            font_family=self.template_config['font_family'],\n",
    "            font_size=self.template_config['font_size'],\n",
    "            margin=self.template_config['margin'],\n",
    "            legend=self.template_config['legend'],\n",
    "            xaxis_rangeslider_visible=False,\n",
    "            height=800 if volume else 600\n",
    "        )\n",
    "        \n",
    "        # Update axes\n",
    "        fig.update_yaxes(title_text=\"價格 (HKD)\", row=1, col=1)\n",
    "        if volume:\n",
    "            fig.update_yaxes(title_text=\"成交量\", row=2, col=1)\n",
    "        \n",
    "        return fig\n",
    "    \n",
    "    def performance_waterfall(self, returns_data, title=\"策略回報分解\"):\n",
    "        \"\"\"策略回報瀑布圖\n",
    "        \n",
    "        Strategy performance waterfall chart\n",
    "        \"\"\"\n",
    "        fig = go.Figure(go.Waterfall(\n",
    "            name=\"回報分解\",\n",
    "            orientation=\"v\",\n",
    "            measure=[\"relative\"] * len(returns_data),\n",
    "            x=[f\"{r:.1%}\" for r in returns_data],\n",
    "            text=[f\"{r:.2%}\" for r in returns_data],\n",
    "            y=returns_data,\n",
    "            connector={\"line\": {\"color\": \"rgb(63, 63, 63)\"}},\n",
    "            decreasing={\"marker\": {\"color\": self.colors['bear']}},\n",
    "            increasing={\"marker\": {\"color\": self.colors['bull']}},\n",
    "            totals={\"marker\": {\"color\": self.colors['primary']}}\n",
    "        ))\n",
    "        \n",
    "        fig.update_layout(\n",
    "            title=dict(text=title, x=0.5),\n",
    "            template=self.template_config['theme'],\n",
    "            font_family=self.template_config['font_family'],\n",
    "            font_size=self.template_config['font_size'],\n",
    "            margin=self.template_config['margin'],\n",
    "            showlegend=False,\n",
    "            height=500\n",
    "        )\n",
    "        \n",
    "        return fig\n",
    "    \n",
    "    def correlation_heatmap(self, correlation_matrix, title=\"資產相關性熱力圖\"):\n",
    "        \"\"\"資產相關性熱力圖\n",
    "        \n",
    "        Asset correlation heatmap\n",
    "        \"\"\"\n",
    "        fig = go.Figure(data=go.Heatmap(\n",
    "            z=correlation_matrix.values,\n",
    "            x=correlation_matrix.columns,\n",
    "            y=correlation_matrix.index,\n",
    "            colorscale='RdYlBu',\n",
    "            zmid=0,\n",
    "            text=correlation_matrix.round(3).values,\n",
    "            texttemplate=\"%{text}\",\n",
    "            textfont={\"size\": 10},\n",
    "            hoverongaps=False\n",
    "        ))\n",
    "        \n",
    "        fig.update_layout(\n",
    "            title=dict(text=title, x=0.5),\n",
    "            template=self.template_config['theme'],\n",
    "            font_family=self.template_config['font_family'],\n",
    "            font_size=self.template_config['font_size'],\n",
    "            margin=self.template_config['margin'],\n",
    "            width=800,\n",
    "            height=600\n",
    "        )\n",
    "        \n",
    "        return fig\n",
    "    \n",
    "    def drawdown_chart(self, equity_curve, drawdown, title=\"回撤分析\"):\n",
    "        \"\"\"回撤分析圖\n",
    "        \n",
    "        Drawdown analysis chart\n",
    "        \"\"\"\n",
    "        fig = make_subplots(\n",
    "            rows=2, cols=1,\n",
    "            shared_xaxes=True,\n",
    "            vertical_spacing=0.05,\n",
    "            subplot_titles=(\"淨值曲線\", \"回撤\"),\n",
    "            row_width=[0.2, 0.7]\n",
    "        )\n",
    "        \n",
    "        # Equity curve\n",
    "        fig.add_trace(\n",
    "            go.Scatter(\n",
    "                x=equity_curve.index,\n",
    "                y=equity_curve.values,\n",
    "                mode='lines',\n",
    "                name=\"淨值\",\n",
    "                line=dict(color=self.colors['primary'], width=2)\n",
    "            ),\n",
    "            row=1, col=1\n",
    "        )\n",
    "        \n",
    "        # Drawdown\n",
    "        fig.add_trace(\n",
    "            go.Scatter(\n",
    "                x=drawdown.index,\n",
    "                y=drawdown.values,\n",
    "                mode='lines',\n",
    "                name=\"回撤\",\n",
    "                fill='tonexty',\n",
    "                fillcolor=f'rgba({int(self.colors[\"danger\"][1:3], 16)}, {int(self.colors[\"danger\"][3:5], 16)}, {int(self.colors[\"danger\"][5:7], 16)}, 0.3)',\n",
    "                line=dict(color=self.colors['danger'], width=2)\n",
    "            ),\n",
    "            row=2, col=1\n",
    "        )\n",
    "        \n",
    "        fig.update_layout(\n",
    "            title=dict(text=title, x=0.5),\n",
    "            template=self.template_config['theme'],\n",
    "            font_family=self.template_config['font_family'],\n",
    "            font_size=self.template_config['font_size'],\n",
    "            margin=self.template_config['margin'],\n",
    "            height=700\n",
    "        )\n",
    "        \n",
    "        fig.update_yaxes(title_text=\"淨值\", row=1, col=1)\n",
    "        fig.update_yaxes(title_text=\"回撤 (%)\", row=2, col=1)\n",
    "        \n",
    "        return fig\n",
    "\n",
    "# Initialize chart templates\n",
    "chart_templates = QuantitativeChartTemplates()\n",
    "print(\"✅ Quantitative Chart Templates Initialized\")\n",
    "print(f\"📊 Available templates: Candlestick, Performance Waterfall, Correlation Heatmap, Drawdown Analysis\")"
   ]
  },

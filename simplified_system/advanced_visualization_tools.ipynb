    "    \n",
    "    def _generate_mock_data(self, symbol, days):\n",
    "        \"\"\"生成模擬數據\n",
    "        \n",
    "        Generate mock data for demonstration\n",
    "        \"\"\"\n",
    "        np.random.seed(42)\n",
    "        dates = pd.date_range(end=datetime.now(), periods=days, freq='D')\n",
    "        \n",
    "        # Base price based on symbol\n",
    "        base_prices = {\n",
    "            '0700.HK': 400,\n",
    "            '0941.HK': 50,\n",
    "            '1398.HK': 4,\n",
    "            '0388.HK': 300\n",
    "        }\n",
    "        \n",
    "        base_price = base_prices.get(symbol, 100)\n",
    "        \n",
    "        # Generate realistic price movements\n",
    "        returns = np.random.normal(0.0005, 0.02, days)  # Daily returns\n",
    "        prices = [base_price]\n",
    "        \n",
    "        for ret in returns[1:]:\n",
    "            new_price = prices[-1] * (1 + ret)\n",
    "            prices.append(max(new_price, base_price * 0.5))  # Prevent negative prices\n",
    "        \n",
    "        prices = np.array(prices)\n",
    "        \n",
    "        # Generate OHLC\n",
    "        high = prices * (1 + np.random.uniform(0, 0.03, days))\n",
    "        low = prices * (1 - np.random.uniform(0, 0.03, days))\n",
    "        open_price = np.roll(prices, 1)\n",
    "        open_price[0] = base_price\n",
    "        \n",
    "        # Ensure OHLC relationships\n",
    "        high = np.maximum(high, np.maximum(open_price, prices))\n",
    "        low = np.minimum(low, np.minimum(open_price, prices))\n",
    "        \n",
    "        df = pd.DataFrame({\n",
    "            'Open': open_price,\n",
    "            'High': high,\n",
    "            'Low': low,\n",
    "            'Close': prices,\n",
    "            'Volume': np.random.randint(1000000, 20000000, days)\n",
    "        }, index=dates)\n",
    "        \n",
    "        return df\n",
    "    \n",
    "    def _calculate_indicators(self, df, selected_indicators):\n",
    "        \"\"\"計算技術指標\n",
    "        \n",
    "        Calculate technical indicators\n",
    "        \"\"\"\n",
    "        df_indicators = df.copy()\n",
    "        \n",
    "        if 'MA5' in selected_indicators:\n",
    "            df_indicators['MA5'] = df['Close'].rolling(window=5).mean()\n",
    "        \n",
    "        if 'MA20' in selected_indicators:\n",
    "            df_indicators['MA20'] = df['Close'].rolling(window=20).mean()\n",
    "        \n",
    "        if 'RSI14' in selected_indicators:\n",
    "            delta = df['Close'].diff()\n",
    "            gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()\n",
    "            loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()\n",
    "            rs = gain / loss\n",
    "            df_indicators['RSI14'] = 100 - (100 / (1 + rs))\n",
    "        \n",
    "        if 'MACD' in selected_indicators:\n",
    "            exp1 = df['Close'].ewm(span=12, adjust=False).mean()\n",
    "            exp2 = df['Close'].ewm(span=26, adjust=False).mean()\n",
    "            df_indicators['MACD'] = exp1 - exp2\n",
    "            df_indicators['MACD_signal'] = df_indicators['MACD'].ewm(span=9, adjust=False).mean()\n",
    "        \n",
    "        if 'BB' in selected_indicators:\n",
    "            ma20 = df['Close'].rolling(window=20).mean()\n",
    "            std20 = df['Close'].rolling(window=20).std()\n",
    "            df_indicators['BB_upper'] = ma20 + (std20 * 2)\n",
    "            df_indicators['BB_lower'] = ma20 - (std20 * 2)\n",
    "        \n",
    "        return df_indicators\n",
    "    \n",
    "    def _generate_statistics_info(self, df):\n",
    "        \"\"\"生成統計信息\n",
    "        \n",
    "        Generate statistics information\n",
    "        \"\"\"\n",
    "        latest_price = df['Close'].iloc[-1]\n",
    "        price_change = df['Close'].iloc[-1] - df['Close'].iloc[0]\n",
    "        price_change_pct = (price_change / df['Close'].iloc[0]) * 100\n",
    "        \n",
    "        volatility = df['Close'].pct_change().std() * np.sqrt(252) * 100\n",
    "        max_price = df['High'].max()\n",
    "        min_price = df['Low'].min()\n",
    "        avg_volume = df['Volume'].mean()\n",
    "        \n",
    "        return [\n",
    "            html.P(f\"最新價格: {latest_price:.2f} HKD\"),\n",
    "            html.P(f\"期間變化: {price_change:+.2f} ({price_change_pct:+.2f}%)\"),\n",
    "            html.P(f\"年化波動率: {volatility:.2f}%\"),\n",
    "            html.P(f\"最高價格: {max_price:.2f} HKD\"),\n",
    "            html.P(f\"最低價格: {min_price:.2f} HKD\"),\n",
    "            html.P(f\"平均成交量: {avg_volume:,.0f}\")\n",
    "        ]\n",
    "    \n",
    "    def _generate_indicators_info(self, df, indicators):\n",
    "        \"\"\"生成指標信息\n",
    "        \n",
    "        Generate indicators information\n",
    "        \"\"\"\n",
    "        info = []\n",
    "        \n",
    "        for indicator in indicators:\n",
    "            if indicator in df.columns and not df[indicator].isna().all():\n",
    "                latest_value = df[indicator].iloc[-1]\n",
    "                if indicator == 'RSI14':\n",
    "                    status = \"超買\" if latest_value > 70 else \"超賣\" if latest_value < 30 else \"中性\"\n",
    "                    info.append(html.P(f\"RSI(14): {latest_value:.1f} ({status})\"))\n",
    "                elif indicator.startswith('MA'):\n",
    "                    trend = \"上升\" if latest_value > df[indicator].iloc[-5] else \"下降\"\n",
    "                    info.append(html.P(f\"{indicator}: {latest_value:.2f} ({trend}趨勢)\"))\n",
    "                elif indicator == 'MACD':\n",
    "                    signal = df['MACD_signal'].iloc[-1] if 'MACD_signal' in df.columns else 0\n",
    "                    status = \"看漲\" if latest_value > signal else \"看跌\"\n",
    "                    info.append(html.P(f\"MACD: {latest_value:.4f} ({status})\"))\n",
    "        \n",
    "        return info\n",
    "    \n",
    "    def run(self, host='127.0.0.1', port=8050, debug=True):\n",
    "        \"\"\"運行Dash應用\n",
    "        \n",
    "        Run Dash application\n",
    "        \"\"\"\n",
    "        print(f\"🌐 Starting Quantitative Analysis Dashboard...\")\n",
    "        print(f\"📊 URL: http://{host}:{port}\")\n",
    "        print(f\"🎯 Features: Real-time charts, Technical indicators, Performance analysis\")\n",
    "        \n",
    "        self.app.run_server(host=host, port=port, debug=debug)\n",
    "\n",
    "# Initialize Dash app\n",
    "dash_app = QuantitativeDashApp()\n",
    "print(\"✅ Dash Application Initialized\")\n",
    "print(f\"🌐 Ready to run: dash_app.run()\")\n",
    "print(f\"🎯 Features: Real-time updates, Interactive charts, Technical analysis\")"

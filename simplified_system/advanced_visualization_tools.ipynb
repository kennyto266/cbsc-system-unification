    "## 🚀 3D可視化與動態圖表 3D Visualization & Dynamic Charts\n",
    "\n",
    "### 高級3D可視化和實時動態圖表功能"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ===================== 3D可視化與動態圖表 3D & Dynamic Visualization =====================\n",
    "\n",
    "class Advanced3DVisualization:\n",
    "    \"\"\"高級3D可視化類\n",
    "    \n",
    "    Advanced 3D visualization class\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        self.color_palette = px.colors.qualitative.Set3\n",
    "    \n",
    "    def risk_return_3d_scatter(self, strategies_data, title=\"策略風險回報3D分析\"):\n",
    "        \"\"\"策略風險回報3D散點圖\n",
    "        \n",
    "        Strategy risk-return 3D scatter plot\n",
    "        \n",
    "        Parameters:\n",
    "        - strategies_data: DataFrame with columns ['strategy', 'return', 'volatility', 'sharpe', 'max_drawdown']\n",
    "        \"\"\"\n",
    "        fig = go.Figure(data=[go.Scatter3d(\n",
    "            x=strategies_data['volatility'],\n",
    "            y=strategies_data['return'],\n",
    "            z=strategies_data['sharpe'],\n",
    "            mode='markers',\n",
    "            marker=dict(\n",
    "                size=strategies_data['max_drawdown'].abs() * 1000 + 5,\n",
    "                color=strategies_data['sharpe'],\n",
    "                colorscale='Viridis',\n",
    "                showscale=True,\n",
    "                colorbar=dict(title=\"Sharpe Ratio\")\n",
    "            ),\n",
    "            text=strategies_data['strategy'],\n",
    "            hovertemplate=(\n",
    "                \"<b>%{text}</b><br>\" +\n",
    "                \"年化回報: %{y:.2%}<br>\" +\n",
    "                \"波動率: %{x:.2%}<br>\" +\n",
    "                \"Sharpe: %{z:.3f}<br>\" +\n",
    "                \"最大回撤: %{marker.size:.2f}%<extra></extra>\"\n",
    "            )\n",
    "        )])\n",
    "        \n",
    "        fig.update_layout(\n",
    "            title=dict(text=title, x=0.5),\n",
    "            scene=dict(\n",
    "                xaxis_title=\"波動率 (Volatility)\",\n",
    "                yaxis_title=\"年化回報 (Annual Return)\",\n",
    "                zaxis_title=\"Sharpe Ratio\",\n",
    "                camera=dict(eye=dict(x=1.5, y=1.5, z=1.5))\n",
    "            ),\n",
    "            width=800,\n",
    "            height=600,\n",
    "            margin=dict(l=0, r=0, b=0, t=40)\n",
    "        )\n",
    "        \n",
    "        return fig\n",
    "    \n",
    "    def portfolio_composition_3d_pie(self, portfolio_data, title=\"投資組合構成3D分析\"):\n",
    "        \"\"\"投資組合構成3D餅圖\n",
    "        \n",
    "        Portfolio composition 3D pie chart\n",
    "        \n",
    "        Parameters:\n",
    "        - portfolio_data: DataFrame with columns ['asset', 'weight', 'return']\n",
    "        \"\"\"\n",
    "        fig = go.Figure(data=[go.Pie(\n",
    "            labels=portfolio_data['asset'],\n",
    "            values=portfolio_data['weight'],\n",
    "            marker=dict(colors=self.color_palette[:len(portfolio_data)]),\n",
    "            textinfo='label+percent+value',\n",
    "            textfont_size=12,\n",
    "            pull=[0.1] * len(portfolio_data),  # Pull out all slices\n",
    "            hovertemplate=(\n",
    "                \"<b>%{label}</b><br>\" +\n",
    "                \"權重: %{percent}<br>\" +\n",
    "                \"回報: %{customdata:.2%}<extra></extra>\"\n",
    "            ),\n",
    "            customdata=portfolio_data['return']\n",
    "        )])\n",
    "        \n",
    "        fig.update_traces(\n",
    "            marker=dict(line=dict(color='#000000', width=2))\n",
    "        )\n",
    "        \n",
    "        fig.update_layout(\n",
    "            title=dict(text=title, x=0.5),\n",
    "            font_size=14,\n",
    "            legend=dict(orientation=\"v\", yanchor=\"middle\", y=0.5, xanchor=\"left\", x=1.01),\n",
    "            margin=dict(l=0, r=150, b=0, t=40),\n",
    "            height=600\n",
    "        )\n",
    "        \n",
    "        return fig\n",
    "    \n",
    "    def dynamic_performance_surface(self, performance_matrix, title=\"策略表現動態曲面\"):\n",
    "        \"\"\"策略表現動態曲面圖\n",
    "        \n",
    "        Strategy performance dynamic surface plot\n",
    "        \n",
    "        Parameters:\n",
    "        - performance_matrix: 2D array of strategy performance across parameters\n",
    "        \"\"\"\n",
    "        fig = go.Figure(data=[go.Surface(\n",
    "            z=performance_matrix,\n",
    "            colorscale='Viridis',\n",
    "            showscale=True,\n",
    "            colorbar=dict(title=\"策略表現\")\n",
    "        )])\n",
    "        \n",
    "        fig.update_layout(\n",
    "            title=dict(text=title, x=0.5),\n",
    "            scene=dict(\n",
    "                xaxis_title=\"參數1\",\n",
    "                yaxis_title=\"參數2\",\n",
    "                zaxis_title=\"策略表現\",\n",
    "                camera=dict(eye=dict(x=1.5, y=1.5, z=1.5))\n",
    "            ),\n",
    "            width=800,\n",
    "            height=600,\n",
    "            margin=dict(l=0, r=0, b=0, t=40)\n",
    "        )\n",
    "        \n",
    "        return fig\n",
    "    \n",
    "    def animated_time_series(self, data_dict, title=\"時間序列動態圖表\"):\n",
    "        \"\"\"時間序列動態圖表\n",
    "        \n",
    "        Animated time series chart\n",
    "        \n",
    "        Parameters:\n",
    "        - data_dict: Dictionary of DataFrames with time series data\n",
    "        \"\"\"\n",
    "        fig = go.Figure()\n",
    "        \n",
    "        for i, (name, df) in enumerate(data_dict.items()):\n",
    "            if 'value' in df.columns and 'date' in df.columns:\n",
    "                fig.add_trace(go.Scatter(\n",
    "                    x=df['date'],\n",
    "                    y=df['value'],\n",
    "                    mode='lines+markers',\n",
    "                    name=name,\n",
    "                    line=dict(color=self.color_palette[i % len(self.color_palette)], width=2),\n",
    "                    visible=False  # Initially hidden for animation\n",
    "                ))\n",
    "        \n",
    "        # Create animation frames\n",
    "        frames = []\n",
    "        for i in range(len(data_dict)):\n",
    "            frame = go.Frame(\n",
    "                data=[go.Scatter(\n",
    "                    x=list(data_dict.values())[i]['date'],\n",
    "                    y=list(data_dict.values())[i]['value'],\n",
    "                    mode='lines+markers',\n",
    "                    name=list(data_dict.keys())[i],\n",
    "                    line=dict(color=self.color_palette[i % len(self.color_palette)], width=3),\n",
    "                    visible=True\n",
    "                )],\n",
    "                name=str(i)\n",
    "            )\n",
    "            frames.append(frame)\n",
    "        \n",
    "        # Add animation controls\n",
    "        fig.frames = frames\n",
    "        \n",
    "        # Add play button and slider\n",
    "        fig.update_layout(\n",
    "            title=dict(text=title, x=0.5),\n",
    "            xaxis_title=\"日期\",\n",
    "            yaxis_title=\"數值\",\n",
    "            updatemenus=[dict(\n",
    "                type=\"buttons\",\n",
    "                direction=\"left\",\n",
    "                buttons=list([\n",
    "                    dict(args=[None, {\"frame\": {\"duration\": 1000, \"redraw\": True}, \"fromcurrent\": True}],\n",
    "                         label=\"▶️ Play\", method=\"animate\"),\n",
    "                    dict(args=[None, {\"frame\": {\"duration\": 0, \"redraw\": True}, \"fromcurrent\": True}],\n",
    "                         label=\"⏸️ Pause\", method=\"animate\"),\n",

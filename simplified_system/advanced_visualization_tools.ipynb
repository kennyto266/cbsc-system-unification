    "## 📈 大規模數據可視化 Large Scale Data Visualization\n",
    "\n",
    "### Bokeh高性能可視化支持10萬+記錄"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ===================== 大規模數據可視化 Large Scale Data Visualization =====================\n",
    "\n",
    "class LargeScaleVisualization:\n",
    "    \"\"\"大規模數據可視化類\n",
    "    \n",
    "    Large scale data visualization class optimized for 100k+ records\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        self.colors = Category20[20]\n",
    "        self.max_points = 100000  # Maximum points for optimal performance\n",
    "    \n",
    "    def large_scale_candlestick(self, df, title=\"大規模K線圖\", sample_size=None):\n",
    "        \"\"\"大規模K線圖（支持10萬+記錄）\n",
    "        \n",
    "        Large scale candlestick chart supporting 100k+ records\n",
    "        \"\"\"\n",
    "        # Data sampling for performance\n",
    "        if len(df) > self.max_points and sample_size is None:\n",
    "            sample_size = self.max_points\n",
    "            step = len(df) // sample_size\n",
    "            df_sampled = df.iloc[::step].copy()\n",
    "        else:\n",
    "            df_sampled = df.copy()\n",
    "        \n",
    "        # Reset index for Bokeh\n",
    "        df_sampled = df_sampled.reset_index()\n",
    "        df_sampled['date'] = pd.to_datetime(df_sampled.iloc[:, 0])\n",
    "        \n",
    "        # Create source data\n",
    "        source = ColumnDataSource(df_sampled)\n",
    "        \n",
    "        # Create figure\n",
    "        p = figure(\n",
    "            x_axis_type=\"datetime\",\n",
    "            title=title,\n",
    "            tools=\"pan,wheel_zoom,box_zoom,reset,save\",\n",
    "            width=1200,\n",
    "            height=600,\n",
    "            x_axis_label=\"日期\",\n",
    "            y_axis_label=\"價格 (HKD)\"\n",
    "        )\n",
    "        \n",
    "        # Add candlestick segments\n",
    "        inc = df_sampled.Close > df_sampled.Open\n",
    "        dec = ~inc\n",
    "        \n",
    "        # Green candles (bull)\n",
    "        p.segment(\n",
    "            df_sampled.date[inc], df_sampled.Low[inc],\n",
    "            df_sampled.date[inc], df_sampled.High[inc],\n",
    "            color=\"#00d084\", line_width=1\n",
    "        )\n",
    "        p.vbar(\n",
    "            df_sampled.date[inc], df_sampled.Close[inc] - df_sampled.Open[inc],\n",
    "            df_sampled.Open[inc], \n",
    "            fill_color=\"#00d084\", line_color=\"#00d084\"\n",
    "        )\n",
    "        \n",
    "        # Red candles (bear)\n",
    "        p.segment(\n",
    "            df_sampled.date[dec], df_sampled.Low[dec],\n",
    "            df_sampled.date[dec], df_sampled.High[dec],\n",
    "            color=\"#ff4757\", line_width=1\n",
    "        )\n",
    "        p.vbar(\n",
    "            df_sampled.date[dec], df_sampled.Close[dec] - df_sampled.Open[dec],\n",
    "            df_sampled.Open[dec],\n",
    "            fill_color=\"#ff4757\", line_color=\"#ff4757\"\n",
    "        )\n",
    "        \n",
    "        # Add hover tool\n",
    "        hover = HoverTool(\n",
    "            tooltips=[\n",
    "                (\"日期\", \"@date{%F}\"),\n",
    "                (\"開盤\", \"@Open{0.00}\"),\n",
    "                (\"最高\", \"@High{0.00}\"),\n",
    "                (\"最低\", \"@Low{0.00}\"),\n",
    "                (\"收盤\", \"@Close{0.00}\")\n",
    "            ],\n",
    "            formatters={\"@date\": \"datetime\"},\n",
    "            mode=\"vline\"\n",
    "        )\n",
    "        \n",
    "        p.add_tools(hover)\n",
    "        \n",
    "        # Format x-axis\n",
    "        p.xaxis.formatter = DatetimeTickFormatter(\n",
    "            months=\"%Y-%m\",\n",
    "            days=\"%Y-%m-%d\"\n",
    "        )\n",
    "        \n",
    "        return p\n",
    "    \n",
    "    def large_scale_heatmap(self, correlation_matrix, title=\"大規模相關性熱力圖\"):\n",
    "        \"\"\"大規模相關性熱力圖\n",
    "        \n",
    "        Large scale correlation heatmap\n",
    "        \"\"\"\n",
    "        # Create figure\n",
    "        p = figure(\n",
    "            title=title,\n",
    "            x_range=list(correlation_matrix.columns),\n",
    "            y_range=list(correlation_matrix.index[::-1]),\n",
    "            width=800,\n",
    "            height=600,\n",
    "            tools=\"hover,save,pan,box_zoom,reset,wheel_zoom\",\n",
    "            x_axis_location=\"above\",\n",
    "            toolbar_location=\"below\"\n",
    "        )\n",
    "        \n",
    "        # Convert correlation matrix to long format\n",
    "        corr_long = correlation_matrix.reset_index().melt(id_vars='index')\n",
    "        corr_long.columns = ['x', 'y', 'correlation']\n",
    "        \n",
    "        # Create color mapper\n",
    "        from bokeh.models import LinearColorMapper\n",
    "        from bokeh.palettes import RdYlBu11\n",
    "        \n",
    "        color_mapper = LinearColorMapper(\n",
    "            palette=RdYlBu11,\n",
    "            low=-1,\n",
    "            high=1\n",
    "        )\n",
    "        \n",
    "        # Create rectangles\n",
    "        p.rect(\n",
    "            x=\"x\", y=\"y\",\n",
    "            width=1, height=1,\n",
    "            source=ColumnDataSource(corr_long),\n",
    "            fill_color={'field': 'correlation', 'transform': color_mapper},\n",
    "            line_color=None\n",
    "        )\n",
    "        \n",
    "        # Add color bar\n",
    "        from bokeh.models import ColorBar\n",
    "        color_bar = ColorBar(\n",
    "            color_mapper=color_mapper,\n",
    "            location=(0, 0),\n",
    "            ticker=Ticker(desired_num_ticks=11)\n",
    "        )\n",
    "        \n",
    "        p.add_layout(color_bar, 'right')\n",
    "        \n",
    "        # Rotate x-axis labels\n",
    "        p.xaxis.major_label_orientation = np.pi / 3\n",
    "        \n",
    "        # Add hover tool\n",
    "        hover = HoverTool(\n",
    "            tooltips=[\n",
    "                (\"X\", \"@x\"),\n",
    "                (\"Y\", \"@y\"),\n",
    "                (\"相關性\", \"@correlation{0.000}\")\n",
    "            ]\n",
    "        )\n",
    "        p.add_tools(hover)\n",
    "        \n",
    "        return p\n",
    "    \n",
    "    def performance_comparison_dashboard(self, strategies_data, title=\"策略表現對比儀表板\"):\n",
    "        \"\"\"策略表現對比儀表板\n",
    "        \n",
    "        Strategy performance comparison dashboard\n",
    "        \"\"\"\n",
    "        # Create multiple charts\n",
    "        charts = []\n",
    "        \n",
    "        # 1. Cumulative returns\n",
    "        p1 = figure(\n",
    "            title=\"累計回報對比\",\n",
    "            x_axis_type=\"datetime\",\n",
    "            width=600,\n",
    "            height=300,\n",
    "            tools=\"pan,wheel_zoom,box_zoom,reset,save\"\n",
    "        )\n",
    "        \n",
    "        for i, (strategy, data) in enumerate(strategies_data.items()):\n",
    "            if isinstance(data, pd.Series) and hasattr(data.index, 'to_pydatetime'):\n",
    "                dates = data.index.to_pydatetime()\n",
    "                p1.line(\n",
    "                    dates, data.values,\n",
    "                    line_width=2,\n",
    "                    color=self.colors[i % len(self.colors)],\n",
    "                    legend_label=strategy\n",
    "                )\n",
    "        \n",
    "        p1.legend.location = \"top_left\"\n",
    "        charts.append(p1)\n",
    "        \n",
    "        # 2. Drawdown comparison\n",
    "        p2 = figure(\n",
    "            title=\"回撤對比\",\n",
    "            x_axis_type=\"datetime\",\n",
    "            width=600,\n",
    "            height=300,\n",
    "            tools=\"pan,wheel_zoom,box_zoom,reset,save\"\n",
    "        )\n",
    "        \n",
    "        for i, (strategy, data) in enumerate(strategies_data.items()):\n",
    "            if isinstance(data, pd.DataFrame) and 'drawdown' in data.columns:\n",
    "                dates = data.index.to_pydatetime()\n",
    "                p2.line(\n",
    "                    dates, data['drawdown'],\n",
    "                    line_width=2,\n",
    "                    color=self.colors[i % len(self.colors)],\n",
    "                    legend_label=strategy\n",
    "                )\n",
    "        \n",
    "        p2.legend.location = \"top_left\"\n",
    "        charts.append(p2)\n",
    "        \n",
    "        # Create dashboard layout\n",
    "        dashboard = gridplot(\n",
    "            [charts],\n",
    "            ncols=1,\n",
    "            sizing_mode=\"stretch_width\"\n",
    "        )\n",
    "        \n",
    "        return dashboard\n",
    "\n",
    "# Initialize large scale visualization\n",
    "large_viz = LargeScaleVisualization()\n",
    "print(\"✅ Large Scale Visualization Class Initialized\")\n",
    "print(f\"📊 Optimized for: {large_viz.max_points:,}+ records\")\n",
    "print(f\"🎯 Available charts: Large Candlestick, Heatmap, Performance Dashboard\")"
   ]

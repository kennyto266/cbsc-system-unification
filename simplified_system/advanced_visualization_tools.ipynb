    "    \n",
    "    def _setup_callbacks(self):\n",
    "        \"\"\"設置回調函數\n",
    "        \n",
    "        Setup callback functions\n",
    "        \"\"\"\n",
    "        @self.app.callback(\n",
    "            [Output('candlestick-chart', 'figure'),\n",

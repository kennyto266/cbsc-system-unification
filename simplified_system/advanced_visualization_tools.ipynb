    "# ===================== 實戰演示 Practical Demonstration =====================\n",
    "\n",
    "def load_simplified_system_data(symbol=\"0700.HK\", days=365):\n",
    "    \"\"\"從Simplified System加載數據\n",
    "    \n",
    "    Load data from Simplified System\n",
    "    \"\"\"\n",
    "    try:\n",
    "        # Try to load real data from Simplified System\n",
    "        from api.stock_api import get_hk_stock_data\n",
    "        data = get_hk_stock_data(symbol, days)\n",
    "        \n",
    "        if data is not None and not data.empty:\n",
    "            print(f\"✅ Loaded {len(data)} records of {symbol} from Simplified System\")\n",
    "            return data\n",
    "        else:\n",
    "            print(f\"⚠️ No data from Simplified System, using mock data\")\n",
    "            return generate_mock_stock_data(symbol, days)\n",
    "    except Exception as e:\n",
    "        print(f\"⚠️ Error loading from Simplified System: {e}\")\n",
    "        return generate_mock_stock_data(symbol, days)\n",
    "\n",
    "def generate_mock_stock_data(symbol=\"0700.HK\", days=365):\n",
    "    \"\"\"生成模擬股票數據\n",
    "    \n",
    "    Generate mock stock data\n",
    "    \"\"\"\n",
    "    np.random.seed(42)\n",
    "    dates = pd.date_range(end=datetime.now(), periods=days, freq='D')\n",
    "    \n",
    "    # Base price based on symbol\n",
    "    base_prices = {\n",
    "        '0700.HK': 400,  # Tencent\n",
    "        '0941.HK': 50,   # China Mobile\n",
    "        '1398.HK': 4,    # ICBC\n",
    "        '0388.HK': 300,  # HKEX\n",
    "        '0005.HK': 350   # HSBC\n",
    "    }\n",
    "    \n",
    "    base_price = base_prices.get(symbol, 100)\n",
    "    \n",
    "    # Generate realistic price movements with trend and volatility\n",
    "    trend = np.linspace(1, 1.2, days)  # 20% upward trend\n",
    "    volatility = np.random.normal(0, 0.02, days)\n",
    "    daily_returns = 0.0005 + volatility  # Small positive drift\n",
    "    \n",
    "    prices = [base_price]\n",
    "    for i, ret in enumerate(daily_returns[1:]):\n",
    "        new_price = prices[-1] * (1 + ret) * trend[i]\n",
    "        prices.append(max(new_price, base_price * 0.3))  # Prevent negative prices\n",
    "    \n",
    "    prices = np.array(prices)\n",
    "    \n",
    "    # Generate OHLC with realistic relationships\n",
    "    open_price = np.roll(prices, 1)\n",
    "    open_price[0] = base_price\n",
    "    \n",
    "    # Daily high and low\n",
    "    high_variation = np.random.uniform(0.01, 0.05, days)\n",
    "    low_variation = np.random.uniform(0.01, 0.05, days)\n",
    "    \n",
    "    high = np.maximum(prices, open_price) * (1 + high_variation)\n",
    "    low = np.minimum(prices, open_price) * (1 - low_variation)\n",
    "    \n",
    "    # Generate volume with correlation to price changes\n",
    "    price_changes = np.abs(np.diff(prices, prepend=prices[0]))\n",
    "    base_volume = np.random.uniform(1000000, 20000000, days)\n",
    "    volume_factor = 1 + (price_changes / prices) * 5\n",
    "    volume = base_volume * volume_factor\n",
    "    volume = volume.astype(int)\n",
    "    \n",
    "    df = pd.DataFrame({\n",
    "        'Open': open_price,\n",
    "        'High': high,\n",
    "        'Low': low,\n",
    "        'Close': prices,\n",
    "        'Volume': volume\n",
    "    }, index=dates)\n",
    "    \n",
    "    return df\n",
    "\n",
    "def demonstration_analysis():\n",
    "    \"\"\"演示分析功能\n",
    "    \n",
    "    Demonstration analysis functions\n",
    "    \"\"\"\n",
    "    print(\"🚀 Starting Advanced Visualization Demonstration...\")\n",
    "    \n",
    "    # Load data\n",
    "    print(\"\\n📊 Loading stock data...\")\n",
    "    df = load_simplified_system_data(\"0700.HK\", 365)\n",
    "    print(f\"Data shape: {df.shape}\")\n",
    "    print(f\"Date range: {df.index[0].date()} to {df.index[-1].date()}\")\n",
    "    print(f\"Price range: {df['Close'].min():.2f} - {df['Close'].max():.2f} HKD\")\n",
    "    \n",
    "    # Calculate technical indicators\n",
    "    print(\"\\n🔬 Calculating technical indicators...\")\n",
    "    df_indicators = df.copy()\n",
    "    \n",
    "    # Moving averages\n",
    "    df_indicators['MA5'] = df['Close'].rolling(window=5).mean()\n",
    "    df_indicators['MA20'] = df['Close'].rolling(window=20).mean()\n",
    "    df_indicators['MA50'] = df['Close'].rolling(window=50).mean()\n",
    "    \n",
    "    # RSI\n",
    "    delta = df['Close'].diff()\n",
    "    gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()\n",
    "    loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()\n",
    "    rs = gain / loss\n",
    "    df_indicators['RSI14'] = 100 - (100 / (1 + rs))\n",
    "    \n",
    "    # MACD\n",
    "    exp1 = df['Close'].ewm(span=12, adjust=False).mean()\n",
    "    exp2 = df['Close'].ewm(span=26, adjust=False).mean()\n",
    "    df_indicators['MACD'] = exp1 - exp2\n",
    "    df_indicators['MACD_signal'] = df_indicators['MACD'].ewm(span=9, adjust=False).mean()\n",
    "    \n",
    "    # Bollinger Bands\n",
    "    df_indicators['BB_upper'] = df_indicators['MA20'] + (df['Close'].rolling(window=20).std() * 2)\n",
    "    df_indicators['BB_lower'] = df_indicators['MA20'] - (df['Close'].rolling(window=20).std() * 2)\n",
    "    \n",
    "    # Performance metrics\n",
    "    df_indicators['Returns'] = df['Close'].pct_change()\n",
    "    df_indicators['Cumulative_Returns'] = (1 + df_indicators['Returns']).cumprod() - 1\n",
    "    \n",
    "    # Drawdown\n",
    "    cummax = df_indicators['Cumulative_Returns'].cummax()\n",
    "    df_indicators['Drawdown'] = ((df_indicators['Cumulative_Returns'] / cummax) - 1) * 100\n",
    "    \n",
    "    print(\"✅ Technical indicators calculated\")\n",
    "    \n",
    "    return df, df_indicators\n",
    "\n",
    "# Run demonstration\n",
    "df_stock, df_with_indicators = demonstration_analysis()\n",
    "\n",
    "print(\"\\n🎯 Advanced Visualization Environment Ready!\")\n",

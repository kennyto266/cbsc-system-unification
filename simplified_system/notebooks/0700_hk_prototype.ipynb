    "    marker_color='lightblue'\n",
    "))\n",
    "\n",
    "fig_volume.update_layout(\n",
    "    title='0700.HK Volume',\n",
    "    xaxis_title='Date',\n",
    "    yaxis_title='Volume',\n",
    "    width=800,\n",
    "    height=300\n",
    ")\n",
    "\n",
    "fig_volume.show()"
   ]

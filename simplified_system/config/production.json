{
  "system": {
    "debug": false,
    "log_level": "INFO",
    "database": {
      "echo": false
    },
    "monitoring": {
      "enabled": true
    }
  },
  "data_source": {
    "cache": {
      "timeout": 600,
      "max_size": 5000
    }
  },
  "performance": {
    "gpu": {
      "enabled": true,
      "auto_detect": true
    },
    "optimization": {
      "max_workers": 32
    }
  },
  "api": {
    "server": {
      "debug": false,
      "reload": false
    },
    "security": {
      "api_key_required": true,
      "allowed_origins": ["https://yourdomain.com"]
    }
  }
}
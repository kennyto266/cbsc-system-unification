# API Configuration (Production)
# Backend API Base URL - Update this to your production backend URL
VITE_API_BASE_URL=https://api.cbsc-trading.com/api

# WebSocket Base URL
VITE_WS_BASE_URL=wss://api.cbsc-trading.com/ws

# App Configuration
VITE_APP_NAME=CBSC Quant Trading System
VITE_APP_VERSION=1.0.0

# Environment (development, staging, production)
VITE_APP_ENV=production

# Feature Flags
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_REALTIME=true
VITE_ENABLE_ANALYTICS=true

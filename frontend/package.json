    "chartjs-chart-matrix": "^3.0.0",
    "chartjs-plugin-annotation": "^3.1.0",
    "chartjs-plugin-zoom": "^2.2.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.0.6",
    "dompurify": "^3.3.1",
    "framer-motion": "^10.16.16",
    "helmet": "^8.1.0",
    "lodash": "^4.17.21",

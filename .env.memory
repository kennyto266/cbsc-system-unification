# Memory optimization settings
NODE_OPTIONS=--max-old-space-size=8192
VITE_CJS_IGNORE_WARNING=true
VITE_BROWSER_BASED_COMPAT_CHECK=false

# Disable some features for memory saving
VITE_DISABLE_SOURCEMAP_IN_DEV=true
VITE_MINIMIZE_BUNDLE=true

# Limit concurrent operations
VITE_MAX_PARALLEL_TRANSFORMS=4
VITE_BUILD_CHUNK_SIZE_LIMIT=500
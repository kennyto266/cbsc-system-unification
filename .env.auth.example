# Authentication Service Environment Configuration
# Copy this file to .env.auth and update with your values

# Service Configuration
PORT=3006
WORKERS=4
CONFIG_PROFILE=production
LOG_LEVEL=info
ACCESS_LOG=true

# Database Configuration
DATABASE_URL=postgresql://cbsc:password@localhost:5432/cbsc
# Alternative: Use separate DB variables
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=cbsc
# DB_USER=cbsc
# DB_PASSWORD=password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT Configuration
# Option 1: Provide keys directly (not recommended for production)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Option 2: Provide key file paths (recommended)
JWT_PRIVATE_KEY_PATH=/app/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/jwt_public.pem

# Token Expiration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
FROM_EMAIL=noreply@cbsc.com

# Password Policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_MAX_AGE_DAYS=90
PASSWORD_HISTORY_COUNT=5

# Account Lockout
LOCKOUT_ATTEMPTS=5
LOCKOUT_MINUTES=30
LOCKOUT_MAX_HOURS=8

# MFA Configuration
MFA_REQUIRED=false
MFA_ISSUER=CBSC

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# Session Management
SESSION_TIMEOUT_MINUTES=30
MAX_SESSIONS_PER_USER=5

# Security Headers
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE=31536000

# CORS Configuration
CORS_ORIGINS=https://cbsc.com,https://api.cbsc.com
CORS_ALLOW_CREDENTIALS=true

# Audit Configuration
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_SENSITIVE_OPERATIONS=true

# Development/Testing
DEBUG=false
TESTING=false
# Configuration Service Environment Variables
# 配置服務環境變量示例

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/config_service

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Security Configuration
CONFIG_ENCRYPTION_KEY=your-32-character-encryption-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Service Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8005
API_RELOAD=false

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8001,http://localhost:8002,http://localhost:8003,http://localhost:8004

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST_SIZE=20

# Cache Configuration
CACHE_DEFAULT_TTL=300
CACHE_MAX_SIZE=10000
CACHE_CLEANUP_INTERVAL=60

# Monitoring Configuration
METRICS_ENABLED=true
METRICS_ENDPOINT=/metrics
METRICS_COLLECT_INTERVAL=30

# Health Check Configuration
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ENDPOINT=/health
HEALTH_CHECK_INTERVAL=30

# Backup Configuration
BACKUP_DIR=backups
BACKUP_AUTO_ENABLED=true
BACKUP_INTERVAL=daily
BACKUP_RETENTION_DAYS=30

# Logging Configuration
LOG_FILE_PATH=logs/config_service.log
LOG_MAX_FILE_SIZE=10485760
LOG_BACKUP_COUNT=5

# SSL Configuration (if using HTTPS)
SSL_CERT_PATH=
SSL_KEY_PATH=

# External Service URLs
EXTERNAL_API_TIMEOUT=30
EXTERNAL_API_RETRY_ATTEMPTS=3

# Email Notification Settings (optional)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Telegram Bot Settings (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Grafana Settings (optional)
GRAFANA_URL=
GRAFANA_API_KEY=

# Prometheus Settings (optional)
PROMETHEUS_URL=
PROMETHEUS_PUSH_GATEWAY_URL=

# Performance Settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

REDIS_MAX_CONNECTIONS=20
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Development Settings
DEV_AUTO_RELOAD=false
DEV_DEBUG_MODE=false
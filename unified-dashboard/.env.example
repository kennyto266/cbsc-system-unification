# CBSC Backend API Configuration
VITE_API_BASE_URL=http://localhost:3003
VITE_WS_URL=ws://localhost:3003

# Development Environment
VITE_NODE_ENV=development

# Authentication
VITE_JWT_SECRET=your-jwt-secret-key

# Database (if needed for local development)
VITE_DB_HOST=localhost
VITE_DB_PORT=5432
VITE_DB_NAME=cbsc_db
VITE_DB_USER=postgres
VITE_DB_PASSWORD=password

# Redis Configuration
VITE_REDIS_URL=redis://localhost:6379

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=true

# External Services
VITE_BINANCE_API_KEY=your-binance-api-key
VITE_BINANCE_API_SECRET=your-binance-api-secret

# Monitoring and Analytics
VITE_SENTRY_DSN=your-sentry-dsn
VITE_GA_TRACKING_ID=your-google-analytics-id